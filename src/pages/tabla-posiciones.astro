<Layout hideHeader title="Tabla de Posiciones" mainClassname="px-6 sm:px-10 pt-24 pb-32">
  <section class="max-w-7xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {gruposFinales.map(({ grupo, equipos }) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur-sm">

          <h2 class="text-center font-bold text-3xl text-amber-300 mb-6 font-anton tracking-wider">
            GRUPO {grupo}
          </h2>

          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-sm mb-6">
              <thead>
                <tr class="bg-white/10 text-white uppercase text-xs">
                  <th class="px-2 py-3 border">POS</th>
                  <th class="px-3 py-3 border text-left">Equipo</th>
                  <th class="px-2 py-3 border text-center text-amber-300">PTS</th>
                  <th class="px-2 py-3 border text-center">PJ</th>
                  <th class="px-2 py-3 border text-center">PG</th>
                  <th class="px-2 py-3 border text-center">PP</th>
                  <th class="px-2 py-3 border text-center">GF</th>
                  <th class="px-2 py-3 border text-center">GC</th>
                  <th class="px-2 py-3 border text-center">DG</th>
                </tr>
              </thead>

              <tbody>
                {equipos.map((team, i) => (
                  <tr class={i < 2 ? "bg-green-500/10" : "bg-red-500/10"}>
                    <td class="px-2 py-2 border text-center font-bold">
                      {i === 0 ? "🥇" : i === 1 ? "🥈" : i + 1}
                    </td>
                    <td class="px-3 py-2 border">{team.equipo}</td>
                    <td class="px-2 py-2 border text-center font-bold text-amber-300">{team.PUNTOS}</td>
                    <td class="px-2 py-2 border text-center">{team.PJ}</td>
                    <td class="px-2 py-2 border text-center text-green-400">{team.PG}</td>
                    <td class="px-2 py-2 border text-center text-red-400">{team.PP}</td>
                    <td class="px-2 py-2 border text-center">{team.GF}</td>
                    <td class="px-2 py-2 border text-center">{team.GC}</td>
                    <td class="px-2 py-2 border text-center text-white/60">{team.DG}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {isAdmin && (
            <div class="mt-4 border-t border-white/10 pt-4 space-y-4">

              <details>
                <summary class="cursor-pointer text-xs font-bold text-green-400 uppercase">
                  ▶ Cargar resultado
                </summary>

                <form class="add-match-form mt-3 flex flex-col gap-2" data-grupo={grupo}>
                  <select name="local">{equipos.map((e:any)=><option value={e.equipo}>{e.equipo}</option>)}</select>
                  <select name="visitante">{equipos.map((e:any)=><option value={e.equipo}>{e.equipo}</option>)}</select>
                  <input name="golesLocal" type="number" value="0" />
                  <input name="golesVisitante" type="number" value="0" />
                  <button type="submit">Guardar partido</button>
                </form>
              </details>

              <div class="space-y-2">
                {(partidos[grupo] || []).map((p:any)=>(
                  <div class="flex justify-between bg-black/40 p-2 rounded">
                    <span>{p.local} {p.golesLocal}-{p.golesVisitante} {p.visitante}</span>
                    <div class="flex gap-2">
                      <button class="edit-btn" data-id={p.id}>✏️</button>
                      <button class="delete-btn" data-id={p.id}>🗑️</button>
                    </div>
                  </div>
                ))}
              </div>

            </div>
          )}

        </div>
      ))}
    </div>

  </section>
</Layout>
