---
import Layout from "@/layouts/Layout.astro";
import { LucideSwords, LucideCalendar, LucideFlame } from "lucide-preact";
import { GuerraJourneyTeaser } from "@/components/streamer-wars/GuerraJourneyTransition";

// Reemplazá estos valores con los reales
const EVENT_DATE = "Próximamente";
const HERO_IMAGE = "/images/guerra.webp";
const HERO_CAPTION =
  "La batalla más épica de la comunidad Saltana está por comenzar. ¿Estás listo?";
---

<Layout title="Guerra de Streamers 2">
  <div class="flex flex-col max-w-5xl mx-auto min-h-screen mt-20 px-4 mb-20">
    {/* ── HEADER ── */}
    <header
      class="relative flex flex-col items-center justify-center mb-14 text-center"
    >
      {/* Ícono superior */}
      <div class="mb-6 animate-fade-in-up">
        <div
          class="inline-flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 p-4 backdrop-blur-sm"
        >
          <LucideSwords size={40} class="text-yellow-400" />
        </div>
      </div>

      {/* Título principal */}
      <h1
        class="font-teko text-6xl md:text-8xl font-bold uppercase tracking-wide text-white leading-none animate-fade-in-up animate-delay-100"
      >
        Guerra de{" "}
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-500"
        >
          Streamers
        </span>{" "}
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-500"
        >
          2
        </span>
      </h1>

      {/* Divisor decorativo */}
      <div
        class="my-6 flex items-center gap-4 w-full max-w-xs animate-fade-in-up animate-delay-150"
      >
        <div
          class="h-px flex-1 bg-gradient-to-r from-transparent to-yellow-400/50"
        >
        </div>
        <LucideFlame size={18} class="text-yellow-400 shrink-0" />
        <div
          class="h-px flex-1 bg-gradient-to-l from-transparent to-yellow-400/50"
        >
        </div>
      </div>

      {/* Subtítulo PRÓXIMAMENTE */}
      <div class="animate-fade-in-up animate-delay-200">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-yellow-400/30 bg-yellow-400/10 px-6 py-2 font-rubik text-sm font-bold uppercase tracking-[0.2em] text-yellow-300"
        >
          <LucideCalendar size={14} />
          {EVENT_DATE}
        </span>
      </div>

      {/* Descripción */}
      <p
        class="mt-6 font-rubik text-lg text-white/60 max-w-xl mx-auto leading-relaxed animate-fade-in-up animate-delay-300"
      >
        La segunda edición del evento más grande de la comunidad Saltana está en
        camino. Prepárate para una guerra sin cuartel.
      </p>
    </header>

    {/* ── IMAGEN PRINCIPAL ── */}
    <div class="relative w-full animate-fade-in-up animate-delay-300 group">
      {/* Marco / tarjeta */}
      <div
        class="relative overflow-hidden rounded-2xl
          border border-white/10
          bg-gray-900/40 backdrop-blur-sm
          transition-all duration-500
          hover:border-yellow-400/40
          hover:shadow-2xl hover:shadow-yellow-400/10"
      >
        {/* Imagen */}
        <div class="relative w-full overflow-hidden" style="height: 520px;">
          <img
            src={HERO_IMAGE}
            alt="Guerra de Streamers 2"
            class="h-full w-full object-contain transition-transform duration-700 group-hover:scale-105 opacity-90"
          />
          {/* Degradado inferior sobre la imagen */}
          <div
            class="absolute inset-0 bg-gradient-to-t from-gray-950/80 via-transparent to-transparent"
          >
          </div>

          {/* Badge flotante sobre la imagen */}
          <div class="absolute top-4 left-4">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-black/60 border border-white/10 px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-white backdrop-blur-md font-rubik"
            >
              <LucideSwords size={12} class="text-yellow-400" />
              Edición 2
            </span>
          </div>
        </div>

        {/* ── PIE DE IMAGEN ── */}
        <div
          class="flex items-start gap-4 px-6 py-5
            border-t border-white/10
            bg-gray-900/60"
        >
          {/* Línea de acento izquierda */}
          <div
            class="mt-1 shrink-0 w-0.5 h-10 rounded-full bg-gradient-to-b from-yellow-400 to-orange-500"
          >
          </div>

          <div>
            <p class="font-rubik text-base text-white/80 leading-relaxed">
              {HERO_CAPTION}
            </p>
            <p
              class="mt-1 font-rubik text-xs text-white/30 uppercase tracking-wider"
            >
              Comunidad Saltana · Guerra de Streamers 2
            </p>
          </div>
        </div>
      </div>

      {/* Glow ambiental de fondo (decorativo) */}
      <div
        class="pointer-events-none absolute -inset-4 -z-10 rounded-3xl opacity-20 blur-3xl bg-gradient-to-br from-yellow-500 via-orange-600 to-transparent"
      >
      </div>
    </div>

    {/* ── CINEMÁTICA NARRATIVA ── */}
    <div class="mt-12 flex justify-center">
      <GuerraJourneyTeaser client:only="preact" />
    </div>

    {/* ── SECCIÓN INFERIOR ── */}
    <div
      class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-4 animate-fade-in-up animate-delay-500"
    >
      {
        [
          {
            icon: LucideSwords,
            label: "Formato",
            value: "Por confirmar",
          },
          {
            icon: LucideCalendar,
            label: "Fecha",
            value: "Próximamente",
          },
          {
            icon: LucideFlame,
            label: "Edición",
            value: "Segunda",
          },
        ].map(({ icon: Icon, label, value }) => (
          <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-gray-900/40 px-5 py-4 backdrop-blur-sm">
            <div class="rounded-lg bg-white/10 p-2 text-yellow-400">
              <Icon size={20} />
            </div>
            <div>
              <p class="font-rubik text-xs text-white/40 uppercase tracking-wider">
                {label}
              </p>
              <p class="font-teko text-xl text-white uppercase leading-tight">
                {value}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
