---
import BancoSaltanoApp from "@/components/banco/BancoSaltanoApp";
import CommunityLayout from "@/layouts/CommunityLayout.astro";
import { getSession } from "auth-astro/server";
import { BancoSaltanoService } from "@/services/banco-saltano";

const session = await getSession(Astro.request);

if (!session) {
  return Astro.redirect("/signin?redirect=/comunidad/banco");
}

const initialSummary = await BancoSaltanoService.getAccountSummary(
  parseInt(session.user.id)
);
---

<CommunityLayout title="Banco Saltano">
  <BancoSaltanoApp initialSummary={initialSummary} client:load />
</CommunityLayout>
