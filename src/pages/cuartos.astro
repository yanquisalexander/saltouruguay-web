---
import Layout from "@/layouts/Layout.astro";
import data from "@/data/cuartos.json";
import { getSession } from "auth-astro/server";

const partidos = data.cuartos;

const session = await getSession(Astro.request);
const isAdmin =
(session?.user as any)?.admin === true ||
(session?.user as any)?.isAdmin === true;

const ganador = (p:any) => {
if (!p) return null;
if (p.g1 > p.g2) return p.equipo1;
if (p.g2 > p.g1) return p.equipo2;
return null;
};

const semi1A = ganador(partidos?.[0]);
const semi1B = ganador(partidos?.[1]);

const semi2A = ganador(partidos?.[2]);
const semi2B = ganador(partidos?.[3]);
---

<Layout title="Bracket Torneo">

<h1 style="text-align:center;margin-bottom:30px;">🏆 BRACKET TORNEO</h1>

<div class="bracket">

<!-- CUARTOS -->

<div class="round">
<h2>Cuartos</h2>

{partidos.map((p:any) => (

<div class="match">

<div class={`team ${p.g1 > p.g2 ? "winner" : ""}`}>
{p.equipo1} <span>{p.g1}</span>
</div>

<div class={`team ${p.g2 > p.g1 ? "winner" : ""}`}>
{p.equipo2} <span>{p.g2}</span>
</div>

{isAdmin && (
<button onclick={`editar(${p.id},${p.g1},${p.g2})`}>
✏️ Editar </button>
)}

</div>
))}

</div>

<!-- SEMIFINALES -->

<div class="round">
<h2>Semifinales</h2>

<div class="match">
<div class="team">{semi1A ?? "Por definir"}</div>
<div class="team">{semi1B ?? "Por definir"}</div>
</div>

<div class="match">
<div class="team">{semi2A ?? "Por definir"}</div>
<div class="team">{semi2B ?? "Por definir"}</div>
</div>

</div>

</div>

<script>

function soloNumero(valor){
return !isNaN(valor) && valor !== "" && valor >= 0
}

async function editar(id,g1,g2){

let nuevo1 = prompt("Goles equipo 1:", g1)
if(!soloNumero(nuevo1)) return alert("Solo números")

let nuevo2 = prompt("Goles equipo 2:", g2)
if(!soloNumero(nuevo2)) return alert("Solo números")

await fetch("/api/cuartos",{
method:"POST",
headers:{ "Content-Type":"application/json"},
body:JSON.stringify({
id,
g1:Number(nuevo1),
g2:Number(nuevo2)
})
})

location.reload()
}

</script>

<style>

.bracket{
display:flex;
justify-content:center;
gap:80px;
flex-wrap:wrap;
}

.round{
display:flex;
flex-direction:column;
gap:20px;
}

.match{
background:#111;
padding:15px;
border-radius:10px;
width:220px;
}

.team{
display:flex;
justify-content:space-between;
padding:6px 0;
}

.winner{
color:#00ff9c;
font-weight:bold;
}

button{
margin-top:10px;
width:100%;
background:#222;
border:none;
padding:6px;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#333;
}

h2{
text-align:center;
}

</style>
