---
import Layout from "@/layouts/Layout.astro";
import partidos from "@/data/cuartos.json";
import { getSession } from "auth-astro/server";

const session = await getSession(Astro.request);
const isAdmin =
  (session?.user as any)?.admin === true ||
  (session?.user as any)?.isAdmin === true;

const ganador = (p:any) => {
  if (!p) return null;
  if (p.goles1 > p.goles2) return p.equipo1;
  if (p.goles2 > p.goles1) return p.equipo2;
  return null;
};

// semifinales seguras
const semi1A = ganador(partidos?.[0]);
const semi1B = ganador(partidos?.[1]);

const semi2A = ganador(partidos?.[2]);
const semi2B = ganador(partidos?.[3]);
---

<Layout hideHeader title="Playoffs" mainClassname="px-6 sm:px-10 pt-24 pb-32">

<section class="max-w-6xl mx-auto">

<div class="text-center mb-12">
<p class="uppercase tracking-[0.1em] text-4xl md:text-6xl font-anton font-bold text-white">
TORNEO ROCKET LEAGUE
</p>

<h1 class="font-anton text-4xl md:text-5xl mt-2 bg-gradient-to-r from-amber-400 to-yellow-300 bg-clip-text text-transparent">
CUARTOS DE FINAL
</h1>
</div>

<div class="grid md:grid-cols-2 gap-8">

{partidos.map((p) => {

const win = ganador(p);

return (

<div class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur-sm">

<p class="text-center text-sm text-amber-400 mb-4 font-bold tracking-widest">
PARTIDO {p.id}
</p>

<div class="flex flex-col gap-3 text-lg">

<div class={`flex justify-between items-center p-3 rounded-lg ${win === p.equipo1 ? "bg-green-500/20 border border-green-400" : "bg-black/40"}`}>
<span class="font-bold">{p.equipo1}</span>
<span class="text-2xl font-anton">{p.goles1}</span>
</div>

<div class={`flex justify-between items-center p-3 rounded-lg ${win === p.equipo2 ? "bg-green-500/20 border border-green-400" : "bg-black/40"}`}>
<span class="font-bold">{p.equipo2}</span>
<span class="text-2xl font-anton">{p.goles2}</span>
</div>

</div>

{win && (
<p class="text-center text-green-400 font-bold mt-4">
🏆 {win} clasifica a SEMIFINALES
</p>
)}

{isAdmin && (
<div class="mt-6 border-t border-white/10 pt-4">

<button
class="edit-btn w-full bg-amber-500 hover:bg-amber-400 text-black font-bold py-2 rounded-lg"
data-id={p.id}
data-g1={p.goles1}
data-g2={p.goles2}
>
✏️ Editar Resultado
</button>

</div>
)}

</div>

);

})}

</div>


<!-- SEMIFINALES -->

<div class="mt-20">

<h2 class="text-center font-anton text-3xl text-amber-300 mb-10">
SEMIFINALES
</h2>

<div class="grid md:grid-cols-2 gap-8">

<div class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur-sm">

<p class="text-center text-sm text-amber-400 mb-4 font-bold tracking-widest">
SEMIFINAL 1
</p>

<div class="flex justify-between items-center p-3 rounded-lg bg-black/40">
<span class="font-bold">{semi1A ?? "Por definir"}</span>
</div>

<div class="flex justify-between items-center p-3 rounded-lg bg-black/40">
<span class="font-bold">{semi1B ?? "Por definir"}</span>
</div>

</div>


<div class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur-sm">

<p class="text-center text-sm text-amber-400 mb-4 font-bold tracking-widest">
SEMIFINAL 2
</p>

<div class="flex justify-between items-center p-3 rounded-lg bg-black/40">
<span class="font-bold">{semi2A ?? "Por definir"}</span>
</div>

<div class="flex justify-between items-center p-3 rounded-lg bg-black/40">
<span class="font-bold">{semi2B ?? "Por definir"}</span>
</div>

</div>

</div>

</div>

</section>

</Layout>

{isAdmin && (
<script>

document.querySelectorAll(".edit-btn").forEach(btn => {

btn.addEventListener("click", async () => {

const id = btn.dataset.id;

const g1 = Number(prompt("Nuevo score equipo 1", btn.dataset.g1));
const g2 = Number(prompt("Nuevo score equipo 2", btn.dataset.g2));

if (isNaN(g1) || isNaN(g2)) {
alert("Debes ingresar números válidos");
return;
}

if (g1 < 0 || g2 < 0) {
alert("Los goles no pueden ser negativos");
return;
}

try {

await fetch("/api/cuartos", {
method:"PUT",
headers:{ "Content-Type":"application/json" },
body: JSON.stringify({
id,
goles1:g1,
goles2:g2
})
});

location.reload();

} catch (err) {

alert("Error al guardar el resultado");
console.error(err);

}

});

});

</script>
)}
