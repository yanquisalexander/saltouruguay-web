---
import { getSession } from "auth-astro/server";
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import { OAuthClientsManager } from "@/components/admin/OAuthClientsManager";

const session = await getSession(Astro.request);
if (!session?.user?.isAdmin) {
    return new Response(null, { status: 404 });
}
---

<AdminLayout title="OAuth Apps" session={session}>
    <div class="flex flex-col max-w-5xl mx-auto min-h-screen mt-4">
        <AdminPageHeader title="OAuth Apps" pathname="/admin/developer/apps" />
        <OAuthClientsManager client:load />
    </div>
</AdminLayout>
