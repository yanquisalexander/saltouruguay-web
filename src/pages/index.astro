---
import Layout from "../layouts/Layout.astro";
import Sponsors from "@/sections/Sponsors.astro";
import LiveStream from "@/components/LiveStream.astro";
import VoteCallToAction from "@/components/VoteCallToAction.astro";
import NewsOnPage from "@/sections/NewsOnPage.astro";
import { FeaturedNews } from "@/components/FeaturedNews";
import Advantages from "@/sections/Advantages.astro";
import Required2FA from "@/components/admin/Required2FA.astro";
import { LucideChevronsDown } from "lucide-preact";

import { CHRISTMAS_MODE } from "@/config";

const IS_PROD = import.meta.env.PROD;
export const prerender = true;

// Lógica de estilos condicionales
const subtitleGradient = CHRISTMAS_MODE
  ? "from-red-500 via-green-500 to-red-500 bg-[length:200%_auto] animate-shine"
  : "from-blue-400 to-purple-500";

const titleShadow = CHRISTMAS_MODE
  ? "drop-shadow-[0_0_15px_rgba(220,38,38,0.5)]"
  : "drop-shadow-lg";
---

<Layout
  title="Comunidad SaltoUruguayServer"
  description="Te damos la bienvenida a la comunidad del canal de SaltoUruguayServer en Twitch. ¡Los #SaltoAwards2025 será un evento inolvidable!"
>
  <main class="relative w-full text-white">
    {/* ❄️ EFECTO DE NIEVE */}
    {
      CHRISTMAS_MODE && (
        <div
          class="fixed inset-0 z-50 pointer-events-none overflow-hidden"
          aria-hidden="true"
        >
          <div class="snow" />
          <div class="snow layer2" />
          <div class="snow layer3" />
        </div>
      )
    }

    <section
      id="hero"
      class="relative -mt-24 flex min-h-dvh w-full flex-col items-center justify-center overflow-hidden"
    >
      {/* Efecto de iluminación atmosférica de fondo (Glow sutil) */}
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.04)_0%,transparent_60%)]"
      >
      </div>

      {/* Fondo de partículas animadas */}
      <div
        class="pointer-events-none absolute inset-0 z-0 overflow-hidden"
        aria-hidden="true"
      >
        <div class="particle particle-1"></div>
        <div class="particle particle-2"></div>
        <div class="particle particle-3"></div>
        <div class="particle particle-4"></div>
        <div class="particle particle-5"></div>
        <div class="particle particle-6"></div>
        <div class="particle particle-7"></div>
        <div class="particle particle-8"></div>
        <div class="particle particle-9"></div>
        <div class="particle particle-10"></div>
        <div class="particle particle-11"></div>
        <div class="particle particle-12"></div>
        <div class="particle particle-13"></div>
        <div class="particle particle-14"></div>
        <div class="particle particle-15"></div>
      </div>

      {/* Formas geométricas flotantes */}
      <div
        class="pointer-events-none absolute inset-0 z-0 overflow-hidden"
        aria-hidden="true"
      >
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
      </div>

      <div
        class="relative z-10 mx-auto flex max-w-6xl flex-col items-center gap-10 px-6 text-center"
      >
        {/* Alertas - Con un toque de glassmorphism */}
        <div
          class="flex w-full max-w-md flex-col items-center gap-3 animate-fade-in-down backdrop-blur-sm"
        >
          <Required2FA server:defer />
        </div>

        <header
          class="flex flex-col items-center justify-center gap-8 md:flex-row md:gap-14"
        >
          {/* Logo - Con un halo de luz sutil al pasar el mouse */}
          <div
            class={`group relative animate-fade-in ${
              CHRISTMAS_MODE ? "christmas-logo" : ""
            }`}
          >
            <div
              class="absolute -inset-4 rounded-full bg-white/5 opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100"
            >
            </div>
            <img
              src="/favicon.svg"
              alt="SaltoUruguayServer Logo"
              draggable="false"
              fetchpriority="high"
              loading="eager"
              class="relative h-28 w-auto object-contain drop-shadow-[0_0_15px_rgba(255,255,255,0.05)] transition-all duration-500 ease-out group-hover:scale-105 group-hover:drop-shadow-[0_0_25px_rgba(255,255,255,0.15)] md:h-40"
            />
          </div>

          {/* Títulos */}
          <div class="animate-fade-in-up space-y-3 text-center md:text-left">
            {
              /* Título Principal - Recupera fuerza, pero con sombras controladas */
            }
            <h1
              class="font-anton text-5xl tracking-wide text-white transition-all duration-500 sm:text-6xl md:text-7xl drop-shadow-[0_4px_24px_rgba(0,0,0,0.4)]"
            >
              SALTO URUGUAY
            </h1>

            {
              /* Subtítulo - Gradiente metálico/sutil en lugar de colores planos */
            }
            <h2
              class="bg-gradient-to-r from-white via-white/80 to-white/40 bg-clip-text font-sans text-lg font-medium tracking-[0.2em] text-transparent md:text-xl"
            >
              SERVER COMMUNITY
            </h2>
          </div>
        </header>
      </div>

      {/* Scroll indicator - Estilo más técnico/gaming */}
      <div
        class="absolute bottom-8 text-white/30 transition-all hover:-translate-y-1 hover:text-white/80 animate-bounce cursor-pointer"
      >
        <LucideChevronsDown size={28} stroke-width="2" />
      </div>
    </section>

    {/* CONTENIDO */}
    <div
      class="relative z-10 mx-auto flex max-w-7xl flex-col gap-24 px-4 pb-20"
    >
      <div id="stream-section" class="scroll-mt-32">
        <LiveStream server:defer />
      </div>

      <FeaturedNews client:only />
      <Advantages />
      <NewsOnPage />
      <Sponsors />
    </div>
  </main>
</Layout>

<style>
  /* Animaciones CSS Puras */
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  .animate-fade-in-down {
    animation: fadeInDown 1s ease-out forwards;
  }

  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.3s forwards;
  }

  /* Animación para el gradiente navideño */
  .animate-shine {
    animation: backgroundShine 3s linear infinite;
  }

  @keyframes backgroundShine {
    0% {
      background-position: 0% 50%;
    }
    100% {
      background-position: 200% 50%;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 🎅 ESTILOS DE NAVIDAD */

  /* Gorrito sobre el logo */
  .christmas-logo::before {
    content: "🎅";
    position: absolute;
    top: -30px;
    left: -20px;
    font-size: 4rem;
    z-index: 20;
    transform: rotate(-15deg);
    animation: bounceHat 2s infinite ease-in-out;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.3));
  }

  @keyframes bounceHat {
    0%,
    100% {
      transform: rotate(-15deg) translateY(0);
    }
    50% {
      transform: rotate(-10deg) translateY(-5px);
    }
  }

  /* Efecto de Nieve (CSS Only - Performance Friendly) */
  .snow {
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      radial-gradient(4px 4px at 100px 50px, #fff, transparent),
      radial-gradient(6px 6px at 200px 150px, #fff, transparent),
      radial-gradient(3px 3px at 300px 250px, #fff 50%, transparent),
      radial-gradient(4px 4px at 400px 350px, #fff 50%, transparent),
      radial-gradient(6px 6px at 500px 100px, #fff 50%, transparent),
      radial-gradient(3px 3px at 50px 200px, #fff 50%, transparent),
      radial-gradient(4px 4px at 150px 300px, #fff 50%, transparent),
      radial-gradient(6px 6px at 250px 400px, #fff 50%, transparent),
      radial-gradient(6px 6px at 350px 500px, #fff 50%, transparent);
    background-size: 550px 550px;
    animation: snow 10s linear infinite;
    opacity: 0.6;
  }

  .snow.layer2 {
    background-image:
      radial-gradient(4px 4px at 50px 250px, #fff, transparent),
      radial-gradient(6px 6px at 150px 350px, #fff, transparent),
      radial-gradient(3px 3px at 250px 450px, #fff 50%, transparent),
      radial-gradient(4px 4px at 350px 50px, #fff 50%, transparent);
    background-size: 350px 350px;
    animation: snow 6s linear infinite reverse;
    opacity: 0.4;
    filter: blur(1px);
  }

  .snow.layer3 {
    background-image: radial-gradient(
      3px 3px at 100px 100px,
      #fff,
      transparent
    );
    background-size: 250px 250px;
    animation: snow 4s linear infinite;
    opacity: 0.3;
  }

  @keyframes snow {
    0% {
      transform: translateY(-550px);
    }
    100% {
      transform: translateY(0);
    }
  }

  /* ✨ PARTÍCULAS ANIMADAS DEL HERO */
  .particle {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(145, 70, 255, 0.8) 0%,
      rgba(145, 70, 255, 0) 70%
    );
    animation: floatParticle linear infinite;
    opacity: 0;
  }

  .particle-1 {
    width: 4px;
    height: 4px;
    left: 10%;
    animation-duration: 20s;
    animation-delay: 0s;
  }
  .particle-2 {
    width: 6px;
    height: 6px;
    left: 20%;
    animation-duration: 25s;
    animation-delay: 2s;
  }
  .particle-3 {
    width: 3px;
    height: 3px;
    left: 35%;
    animation-duration: 18s;
    animation-delay: 4s;
  }
  .particle-4 {
    width: 5px;
    height: 5px;
    left: 50%;
    animation-duration: 22s;
    animation-delay: 1s;
  }
  .particle-5 {
    width: 4px;
    height: 4px;
    left: 65%;
    animation-duration: 28s;
    animation-delay: 3s;
  }
  .particle-6 {
    width: 7px;
    height: 7px;
    left: 75%;
    animation-duration: 19s;
    animation-delay: 5s;
  }
  .particle-7 {
    width: 3px;
    height: 3px;
    left: 85%;
    animation-duration: 24s;
    animation-delay: 2s;
  }
  .particle-8 {
    width: 5px;
    height: 5px;
    left: 90%;
    animation-duration: 21s;
    animation-delay: 6s;
  }
  .particle-9 {
    width: 4px;
    height: 4px;
    left: 5%;
    animation-duration: 26s;
    animation-delay: 7s;
  }
  .particle-10 {
    width: 6px;
    height: 6px;
    left: 45%;
    animation-duration: 23s;
    animation-delay: 8s;
  }
  .particle-11 {
    width: 3px;
    height: 3px;
    left: 55%;
    animation-duration: 27s;
    animation-delay: 1s;
  }
  .particle-12 {
    width: 5px;
    height: 5px;
    left: 30%;
    animation-duration: 20s;
    animation-delay: 4s;
  }
  .particle-13 {
    width: 4px;
    height: 4px;
    left: 70%;
    animation-duration: 22s;
    animation-delay: 9s;
  }
  .particle-14 {
    width: 6px;
    height: 6px;
    left: 15%;
    animation-duration: 25s;
    animation-delay: 3s;
  }
  .particle-15 {
    width: 3px;
    height: 3px;
    left: 60%;
    animation-duration: 19s;
    animation-delay: 6s;
  }

  @keyframes floatParticle {
    0% {
      transform: translateY(100vh) translateX(0);
      opacity: 0;
    }
    10% {
      opacity: 0.6;
    }
    90% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(-100px) translateX(50px);
      opacity: 0;
    }
  }

  /* 🔷 FORMAS GEOMÉTRICAS FLOTANTES */
  .floating-shape {
    position: absolute;
    opacity: 0.03;
    animation: floatShape 15s ease-in-out infinite;
  }

  .shape-1 {
    width: 200px;
    height: 200px;
    top: 20%;
    left: 10%;
    border: 2px solid rgba(145, 70, 255, 0.5);
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    animation-duration: 20s;
  }

  .shape-2 {
    width: 150px;
    height: 150px;
    top: 60%;
    right: 15%;
    border: 2px solid rgba(168, 85, 247, 0.5);
    transform: rotate(45deg);
    animation-duration: 18s;
    animation-delay: 3s;
  }

  .shape-3 {
    width: 100px;
    height: 100px;
    bottom: 25%;
    left: 20%;
    border: 2px solid rgba(192, 132, 252, 0.5);
    border-radius: 50%;
    animation-duration: 22s;
    animation-delay: 6s;
  }

  @keyframes floatShape {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    25% {
      transform: translateY(-30px) rotate(90deg);
    }
    50% {
      transform: translateY(0) rotate(180deg);
    }
    75% {
      transform: translateY(30px) rotate(270deg);
    }
  }
</style>
