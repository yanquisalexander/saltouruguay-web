---
/**
 * pages/penca/index.astro
 * Página del jugador: formulario de predicciones + tabla de posiciones.
 * Requiere sesión de Auth.js (redirige al login si no está autenticado).
 */
import { getSession } from "auth-astro/server";
import { getMatches, getUserPicks, getUserScore, getUserRank, getLeaderboard, getUserChampionPick } from "@/lib/penca";

const session = await getSession(Astro.request);
if (!session?.user) {
  return Astro.redirect("/api/auth/signin");
}

const userId = session.user.email!;
const [matches, picks, score, rank, leaderboard, championPick] = await Promise.all([
  getMatches(),
  getUserPicks(userId),
  getUserScore(userId),
  getUserRank(userId),
  getLeaderboard(20),
  getUserChampionPick(userId),
]);

// Separar partidos por fase
const now = Date.now();
const groupMatches = matches
  .filter(m => m.phase === "groups")
  .sort((a, b) => a.kickoff - b.kickoff);
const knockoutMatches = matches
  .filter(m => m.phase !== "groups")
  .sort((a, b) => a.kickoff - b.kickoff);

const PHASE_LABELS: Record<string, string> = {
  groups: "Fase de Grupos",
  round_of_16: "Octavos de Final",
  quarters: "Cuartos de Final",
  semis: "Semifinales",
  final: "Final",
};

// Equipos para selección de campeón (todos los del torneo)
const ALL_TEAMS = [
  { id: "ARG", name: "Argentina", flag: "🇦🇷" },
  { id: "BRA", name: "Brasil", flag: "🇧🇷" },
  { id: "URU", name: "Uruguay", flag: "🇺🇾" },
  { id: "FRA", name: "Francia", flag: "🇫🇷" },
  { id: "ENG", name: "Inglaterra", flag: "🏴󠁧󠁢󠁥󠁮󠁧󠁿" },
  { id: "ESP", name: "España", flag: "🇪🇸" },
  { id: "GER", name: "Alemania", flag: "🇩🇪" },
  { id: "POR", name: "Portugal", flag: "🇵🇹" },
  { id: "MEX", name: "México", flag: "🇲🇽" },
  { id: "USA", name: "Estados Unidos", flag: "🇺🇸" },
  { id: "CAN", name: "Canadá", flag: "🇨🇦" },
  { id: "MAR", name: "Marruecos", flag: "🇲🇦" },
  // Completá con los 48 equipos clasificados
];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Penca Mundial 2026 | Salto Uruguay Server</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;800&family=Barlow:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --gold: #F5C518;
      --gold-dark: #C49A10;
      --green: #1A7C3E;
      --green-light: #2AAA59;
      --bg: #0F1117;
      --surface: #1A1D27;
      --surface2: #22263A;
      --border: rgba(255,255,255,0.08);
      --text: #F0F0F0;
      --text-muted: #8B8FA8;
      --radius: 10px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 15px;
      min-height: 100vh;
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(135deg, #0A4D2A 0%, #0F1117 60%);
      border-bottom: 2px solid var(--gold);
      padding: 20px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .header-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 28px;
      font-weight: 800;
      letter-spacing: 1px;
      color: var(--gold);
      text-transform: uppercase;
    }
    .header-sub { color: var(--text-muted); font-size: 13px; margin-top: 2px; }
    .user-badge {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 6px 14px;
      font-size: 13px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .user-badge .rank { color: var(--gold); font-weight: 600; }

    /* ── Layout ── */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 24px 16px;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 24px;
    }
    @media (max-width: 768px) {
      .container { grid-template-columns: 1fr; }
    }

    /* ── Tabs ── */
    .tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
      background: var(--surface);
      border-radius: var(--radius);
      padding: 4px;
    }
    .tab {
      flex: 1;
      padding: 8px 12px;
      border-radius: 7px;
      border: none;
      background: transparent;
      color: var(--text-muted);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.15s;
    }
    .tab.active {
      background: var(--green);
      color: white;
    }

    /* ── Campeón ── */
    .champion-card {
      background: var(--surface);
      border: 1px solid var(--gold);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 20px;
    }
    .champion-card h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--gold);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .champion-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
      gap: 8px;
    }
    .champion-btn {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 8px;
      color: var(--text);
      font-size: 13px;
      cursor: pointer;
      text-align: center;
      transition: all 0.15s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }
    .champion-btn:hover { border-color: var(--gold); background: rgba(245,197,24,0.08); }
    .champion-btn.selected {
      border-color: var(--gold);
      background: rgba(245,197,24,0.15);
      color: var(--gold);
      font-weight: 600;
    }
    .champion-btn .flag { font-size: 22px; }

    /* ── Match cards ── */
    .phase-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-muted);
      margin: 20px 0 10px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
    }

    .match-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 10px;
      transition: border-color 0.15s;
    }
    .match-card.locked { opacity: 0.6; }
    .match-card.has-pick { border-color: rgba(42,170,89,0.4); }
    .match-card.has-pick.correct { border-color: rgba(42,170,89,0.8); background: rgba(42,170,89,0.06); }
    .match-card.has-pick.incorrect { border-color: rgba(200,60,60,0.5); background: rgba(200,60,60,0.05); }

    .match-meta {
      font-size: 11px;
      color: var(--text-muted);
      margin-bottom: 10px;
      display: flex;
      justify-content: space-between;
    }
    .match-teams {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }
    .team { display: flex; align-items: center; gap: 8px; font-weight: 500; }
    .team.away { justify-content: flex-end; }
    .team .flag-big { font-size: 24px; }
    .score-display {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 800;
      color: var(--gold);
      text-align: center;
      min-width: 60px;
    }
    .score-display.pending { color: var(--text-muted); font-size: 16px; }

    .pick-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
    }
    .pick-btn {
      padding: 8px 4px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text-muted);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.15s;
      text-align: center;
    }
    .pick-btn:hover:not(:disabled) { border-color: rgba(255,255,255,0.3); color: var(--text); }
    .pick-btn.selected-home { background: rgba(42,170,89,0.2); border-color: var(--green-light); color: #7EE8A2; }
    .pick-btn.selected-draw { background: rgba(100,120,200,0.2); border-color: #6478C8; color: #AAB4FF; }
    .pick-btn.selected-away { background: rgba(200,80,80,0.2); border-color: #C85050; color: #FFA0A0; }
    .pick-btn:disabled { cursor: not-allowed; opacity: 0.5; }

    .save-indicator {
      font-size: 11px;
      color: var(--green-light);
      text-align: right;
      margin-top: 6px;
      min-height: 16px;
    }

    /* ── Score inputs ── */
    .score-inputs {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 10px;
      justify-content: center;
    }
    .score-input {
      width: 44px;
      text-align: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 18px;
      padding: 4px;
    }
    .score-input:focus { outline: none; border-color: rgba(255,255,255,0.3); }
    .score-sep { color: var(--text-muted); font-size: 16px; }
    .score-hint { font-size: 11px; color: var(--text-muted); text-align: center; margin-top: 4px; }

    /* ── Leaderboard sidebar ── */
    .sidebar-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      position: sticky;
      top: 20px;
    }
    .sidebar-header {
      background: var(--green);
      padding: 14px 16px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .lb-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      transition: background 0.1s;
    }
    .lb-row:last-child { border-bottom: none; }
    .lb-row.me { background: rgba(245,197,24,0.08); }
    .lb-rank {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 15px;
      font-weight: 800;
      min-width: 24px;
      color: var(--text-muted);
    }
    .lb-rank.top1 { color: var(--gold); }
    .lb-rank.top2 { color: #C0C0C0; }
    .lb-rank.top3 { color: #CD7F32; }
    .lb-name { flex: 1; font-size: 14px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-score {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 800;
      color: var(--gold);
    }
    .lb-pts-label { font-size: 10px; color: var(--text-muted); }

    .points-legend {
      padding: 14px 16px;
      border-top: 1px solid var(--border);
      margin-top: 8px;
    }
    .points-legend h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .points-row {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      padding: 3px 0;
      color: var(--text-muted);
    }
    .points-row .pts { color: var(--gold); font-weight: 600; }
  </style>
</head>
<body>

<header class="header">
  <div>
    <div class="header-title">⚽ Penca Mundial 2026</div>
    <div class="header-sub">Predecí, competí, ganate la gloria</div>
  </div>
  <div class="user-badge">
    {session.user.image && <img src={session.user.image} width="24" height="24" style="border-radius:50%" alt="" />}
    <span>{session.user.name ?? session.user.email}</span>
    {rank > 0 && <span class="rank">#{rank}</span>}
    {score > 0 && <span style="color:var(--gold-dark)">{score} pts</span>}
  </div>
</header>

<div class="container">
  <main>
    <!-- Selección de campeón -->
    <div class="champion-card">
      <h2>🏆 Tu campeón</h2>
      <div class="champion-grid" id="champion-grid">
        {ALL_TEAMS.map(team => (
          <button
            class={`champion-btn ${championPick === team.id ? "selected" : ""}`}
            data-team={team.id}
            onclick={`pickChampion('${team.id}', this)`}
          >
            <span class="flag">{team.flag}</span>
            <span>{team.name}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Tabs de fases -->
    <div class="tabs">
      <button class="tab active" onclick="showTab('groups', this)">Grupos</button>
      <button class="tab" onclick="showTab('knockout', this)">Eliminatorias</button>
    </div>

    <!-- Partidos de grupos -->
    <div id="tab-groups">
      {groupMatches.length === 0 && (
        <p style="color:var(--text-muted);text-align:center;padding:40px 0">
          Los partidos de grupos se publicarán pronto.
        </p>
      )}
      {groupMatches.map(match => {
        const isLocked = now >= match.kickoff;
        const pick = picks[match.id];
        const hasPick = !!pick;
        const hasResult = match.result !== null;
        const isCorrect = hasResult && pick?.prediction === match.result;
        const isIncorrect = hasResult && pick && pick.prediction !== match.result;

        return (
          <div
            class={`match-card ${isLocked ? "locked" : ""} ${hasPick ? "has-pick" : ""} ${isCorrect ? "correct" : ""} ${isIncorrect ? "incorrect" : ""}`}
            id={`match-${match.id}`}
          >
            <div class="match-meta">
              <span>{new Date(match.kickoff).toLocaleString("es-UY", { weekday: "short", day: "2-digit", month: "short", hour: "2-digit", minute: "2-digit" })}</span>
              {isLocked && !hasResult && <span>🔒 Cerrado</span>}
              {hasResult && <span style="color:var(--green-light)">✓ Resultado cargado</span>}
              {hasPick && !isLocked && <span style="color:var(--green-light)">✓ Predicción guardada</span>}
            </div>

            <div class="match-teams">
              <div class="team">
                <span class="flag-big">{match.homeFlag}</span>
                <span>{match.home}</span>
              </div>
              <div class={`score-display ${hasResult ? "" : "pending"}`}>
                {hasResult
                  ? `${match.homeScore} - ${match.awayScore}`
                  : "vs"}
              </div>
              <div class="team away">
                <span>{match.away}</span>
                <span class="flag-big">{match.awayFlag}</span>
              </div>
            </div>

            {!isLocked && (
              <>
                <div class="pick-buttons">
                  <button
                    class={`pick-btn ${pick?.prediction === "home" ? "selected-home" : ""}`}
                    id={`btn-${match.id}-home`}
                    onclick={`savePick('${match.id}', 'home')`}
                  >
                    Gana {match.home}
                  </button>
                  <button
                    class={`pick-btn ${pick?.prediction === "draw" ? "selected-draw" : ""}`}
                    id={`btn-${match.id}-draw`}
                    onclick={`savePick('${match.id}', 'draw')`}
                  >
                    Empate
                  </button>
                  <button
                    class={`pick-btn ${pick?.prediction === "away" ? "selected-away" : ""}`}
                    id={`btn-${match.id}-away`}
                    onclick={`savePick('${match.id}', 'away')`}
                  >
                    Gana {match.away}
                  </button>
                </div>
                <div class="score-inputs">
                  <input
                    class="score-input"
                    type="number"
                    min="0"
                    max="20"
                    id={`hs-${match.id}`}
                    value={pick?.homeScore ?? ""}
                    placeholder="0"
                    onchange={`updateScore('${match.id}')`}
                  />
                  <span class="score-sep">-</span>
                  <input
                    class="score-input"
                    type="number"
                    min="0"
                    max="20"
                    id={`as-${match.id}`}
                    value={pick?.awayScore ?? ""}
                    placeholder="0"
                    onchange={`updateScore('${match.id}')`}
                  />
                </div>
                <div class="score-hint">Marcador exacto (+2 pts bonus)</div>
                <div class="save-indicator" id={`saved-${match.id}`}></div>
              </>
            )}

            {isLocked && pick && (
              <div style="font-size:13px;color:var(--text-muted);margin-top:8px;text-align:center">
                Tu predicción: <strong style="color:var(--text)">
                  {pick.prediction === "home" ? `Gana ${match.home}` : pick.prediction === "away" ? `Gana ${match.away}` : "Empate"}
                  {pick.homeScore !== null ? ` (${pick.homeScore}-${pick.awayScore})` : ""}
                </strong>
                {isCorrect && <span style="color:var(--green-light);margin-left:6px">✓ Correcto</span>}
                {isIncorrect && <span style="color:#C85050;margin-left:6px">✗ Incorrecto</span>}
              </div>
            )}
          </div>
        );
      })}
    </div>

    <!-- Partidos eliminatorias -->
    <div id="tab-knockout" style="display:none">
      {knockoutMatches.length === 0 && (
        <p style="color:var(--text-muted);text-align:center;padding:40px 0">
          Los cruces de eliminatorias se actualizan al finalizar la fase de grupos.
        </p>
      )}
      {/* Mismo template que groups — aquí se renderizan dinámicamente */}
    </div>
  </main>

  <!-- Sidebar: Leaderboard -->
  <aside>
    <div class="sidebar-card">
      <div class="sidebar-header">
        🏅 Tabla
        <span style="font-size:12px;font-weight:400;opacity:0.7">Top 20</span>
      </div>
      {leaderboard.map(entry => (
        <div class={`lb-row ${entry.userId === userId ? "me" : ""}`}>
          <div class={`lb-rank ${entry.rank === 1 ? "top1" : entry.rank === 2 ? "top2" : entry.rank === 3 ? "top3" : ""}`}>
            {entry.rank === 1 ? "🥇" : entry.rank === 2 ? "🥈" : entry.rank === 3 ? "🥉" : `#${entry.rank}`}
          </div>
          <div class="lb-name" title={entry.username}>
            {entry.userId === userId ? <strong>{entry.username}</strong> : entry.username}
          </div>
          <div>
            <div class="lb-score">{entry.score}</div>
            <div class="lb-pts-label">pts</div>
          </div>
        </div>
      ))}
      {leaderboard.length === 0 && (
        <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px">
          Todavía no hay puntajes.<br/>¡Sé el primero en predecir!
        </div>
      )}

      <div class="points-legend">
        <h3>Sistema de puntos</h3>
        <div class="points-row">
          <span>Resultado correcto</span>
          <span class="pts">3 pts</span>
        </div>
        <div class="points-row">
          <span>Marcador exacto (bonus)</span>
          <span class="pts">+2 pts</span>
        </div>
        <div class="points-row">
          <span>Campeón correcto</span>
          <span class="pts">10 pts</span>
        </div>
      </div>
    </div>
  </aside>
</div>

<script>
  // ── Tabs ──────────────────────────────────────────────────────────────────
  function showTab(tab, btn) {
    document.getElementById("tab-groups").style.display = tab === "groups" ? "block" : "none";
    document.getElementById("tab-knockout").style.display = tab === "knockout" ? "block" : "none";
    document.querySelectorAll(".tab").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  }

  // ── Guardar predicción ────────────────────────────────────────────────────
  async function savePick(matchId, prediction) {
    const homeScore = document.getElementById(`hs-${matchId}`)?.value;
    const awayScore = document.getElementById(`as-${matchId}`)?.value;

    // Actualizar UI inmediatamente
    ["home", "draw", "away"].forEach(opt => {
      const btn = document.getElementById(`btn-${matchId}-${opt}`);
      if (!btn) return;
      btn.classList.remove("selected-home", "selected-draw", "selected-away");
    });
    const selected = document.getElementById(`btn-${matchId}-${prediction}`);
    if (selected) selected.classList.add(`selected-${prediction}`);

    const savedEl = document.getElementById(`saved-${matchId}`);

    try {
      const res = await fetch("/api/penca/picks", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          matchId,
          prediction,
          homeScore: homeScore !== "" ? Number(homeScore) : null,
          awayScore: awayScore !== "" ? Number(awayScore) : null,
        }),
      });
      const data = await res.json();
      if (data.ok) {
        if (savedEl) {
          savedEl.textContent = "✓ Guardado";
          setTimeout(() => { if (savedEl) savedEl.textContent = ""; }, 2000);
        }
      } else {
        if (savedEl) savedEl.textContent = data.error || "Error al guardar";
      }
    } catch {
      if (savedEl) savedEl.textContent = "Error de conexión";
    }
  }

  // ── Actualizar marcador sin cambiar predicción ─────────────────────────────
  function updateScore(matchId) {
    const activeBtn = document.querySelector(`[id^="btn-${matchId}-"].selected-home, [id^="btn-${matchId}-"].selected-draw, [id^="btn-${matchId}-"].selected-away`);
    if (!activeBtn) return;
    const prediction = activeBtn.id.split("-").pop();
    savePick(matchId, prediction);
  }

  // ── Campeón ───────────────────────────────────────────────────────────────
  async function pickChampion(teamId, btn) {
    // Optimistic UI
    document.querySelectorAll(".champion-btn").forEach(b => b.classList.remove("selected"));
    btn.classList.add("selected");

    try {
      const res = await fetch("/api/penca/champion", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ teamId }),
      });
      const data = await res.json();
      if (!data.ok) {
        alert(data.error || "No se pudo guardar el campeón");
        btn.classList.remove("selected");
      }
    } catch {
      alert("Error de conexión");
      btn.classList.remove("selected");
    }
  }

  window.showTab = showTab;
  window.savePick = savePick;
  window.updateScore = updateScore;
  window.pickChampion = pickChampion;
</script>

</body>
</html>
