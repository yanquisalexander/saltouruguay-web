---
/**
 * pages/penca/admin.astro
 * Panel del streamer para cargar resultados y gestionar la penca.
 * Protegido por ADMIN_SECRET (igual que el bolillero del bingo).
 */
import { getMatches, getLeaderboard } from "@/lib/penca";

// Protección server-side: redirigir si no tiene el secret en cookie/header
// En producción podés agregar un check de sesión más robusto
const adminSecret = import.meta.env.ADMIN_SECRET;
const cookieSecret = Astro.cookies.get("admin_secret")?.value;
const isAuthorized = cookieSecret === adminSecret;

if (!isAuthorized) {
  return Astro.redirect("/penca/admin/login");
}

const [matches, leaderboard] = await Promise.all([
  getMatches(),
  getLeaderboard(100),
]);

const matchesByPhase = {
  groups: matches.filter(m => m.phase === "groups").sort((a,b) => a.kickoff - b.kickoff),
  round_of_16: matches.filter(m => m.phase === "round_of_16").sort((a,b) => a.kickoff - b.kickoff),
  quarters: matches.filter(m => m.phase === "quarters").sort((a,b) => a.kickoff - b.kickoff),
  semis: matches.filter(m => m.phase === "semis").sort((a,b) => a.kickoff - b.kickoff),
  final: matches.filter(m => m.phase === "final"),
};

const PHASE_LABELS: Record<string, string> = {
  groups: "Fase de Grupos",
  round_of_16: "Octavos de Final",
  quarters: "Cuartos de Final",
  semis: "Semifinales",
  final: "Final",
};

const pending = matches.filter(m => m.result === null && Date.now() >= m.kickoff);
const withResult = matches.filter(m => m.result !== null);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Penca | Salto Uruguay Server</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;800&family=Barlow:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --gold: #F5C518;
      --green: #1A7C3E;
      --green-light: #2AAA59;
      --red: #C84040;
      --bg: #0F1117;
      --surface: #1A1D27;
      --surface2: #22263A;
      --border: rgba(255,255,255,0.08);
      --text: #F0F0F0;
      --text-muted: #8B8FA8;
      --radius: 10px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Barlow', sans-serif; font-size: 15px; min-height: 100vh; }

    /* Header */
    .header {
      background: linear-gradient(135deg, #2A0A0A 0%, #0F1117 60%);
      border-bottom: 2px solid var(--red);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .header-title { font-family: 'Barlow Condensed', sans-serif; font-size: 24px; font-weight: 800; color: var(--red); text-transform: uppercase; letter-spacing: 1px; }
    .header-sub { color: var(--text-muted); font-size: 12px; margin-top: 2px; }
    .header-actions { display: flex; gap: 8px; }

    /* Layout */
    .container { max-width: 1200px; margin: 0 auto; padding: 24px 16px; display: grid; grid-template-columns: 1fr 300px; gap: 24px; }
    @media (max-width: 900px) { .container { grid-template-columns: 1fr; } }

    /* Stats bar */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }
    @media (max-width: 600px) { .stats-bar { grid-template-columns: repeat(2, 1fr); } }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      text-align: center;
    }
    .stat-value { font-family: 'Barlow Condensed', sans-serif; font-size: 32px; font-weight: 800; color: var(--gold); }
    .stat-label { font-size: 12px; color: var(--text-muted); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

    /* Alert pendientes */
    .alert {
      background: rgba(200,64,64,0.12);
      border: 1px solid rgba(200,64,64,0.4);
      border-radius: var(--radius);
      padding: 12px 16px;
      margin-bottom: 20px;
      font-size: 13px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .alert .count { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 800; color: var(--red); }

    /* Section */
    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-muted);
      margin: 20px 0 10px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* Match row */
    .match-row {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      margin-bottom: 8px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: center;
      transition: border-color 0.15s;
    }
    .match-row.pending-result { border-color: rgba(200,64,64,0.4); background: rgba(200,64,64,0.04); }
    .match-row.done { border-color: rgba(42,170,89,0.3); background: rgba(42,170,89,0.04); }

    .match-info { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .match-teams-text {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .match-kick { font-size: 12px; color: var(--text-muted); }
    .result-badge {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 14px;
      font-weight: 800;
      background: rgba(42,170,89,0.2);
      color: #7EE8A2;
      border: 1px solid rgba(42,170,89,0.4);
      border-radius: 6px;
      padding: 2px 10px;
    }

    /* Score form inline */
    .score-form { display: flex; align-items: center; gap: 8px; }
    .score-in {
      width: 40px;
      text-align: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 18px;
      padding: 4px 0;
    }
    .score-in:focus { outline: none; border-color: rgba(255,255,255,0.3); }
    .score-sep { color: var(--text-muted); }

    /* Buttons */
    .btn {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 8px 16px;
      border-radius: 7px;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn:hover { opacity: 0.85; }
    .btn:active { transform: scale(0.97); }
    .btn-primary { background: var(--green); color: white; }
    .btn-danger { background: var(--red); color: white; }
    .btn-gold { background: var(--gold); color: #1A1200; }
    .btn-ghost {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-muted);
    }
    .btn-sm { padding: 5px 12px; font-size: 12px; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Champion section */
    .champion-section {
      background: var(--surface);
      border: 1px solid var(--gold);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 24px;
    }
    .champion-section h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
      letter-spacing: 1px;
    }
    .champion-controls { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
    .champion-input {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 7px;
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 14px;
      padding: 8px 12px;
      flex: 1;
      min-width: 120px;
    }
    .champion-input:focus { outline: none; border-color: var(--gold); }

    /* Leaderboard sidebar */
    .sidebar-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      position: sticky;
      top: 20px;
      max-height: 90vh;
      overflow-y: auto;
    }
    .sidebar-header {
      background: var(--green);
      padding: 12px 16px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 15px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      position: sticky;
      top: 0;
    }
    .lb-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      border-bottom: 1px solid var(--border);
    }
    .lb-row:last-child { border-bottom: none; }
    .lb-rank { font-family: 'Barlow Condensed', sans-serif; font-size: 14px; font-weight: 800; min-width: 28px; color: var(--text-muted); }
    .lb-rank.top1 { color: var(--gold); }
    .lb-rank.top2 { color: #C0C0C0; }
    .lb-rank.top3 { color: #CD7F32; }
    .lb-name { flex: 1; font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-score { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 800; color: var(--gold); }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: var(--green);
      color: white;
      padding: 12px 20px;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 500;
      opacity: 0;
      transform: translateY(12px);
      transition: all 0.25s;
      pointer-events: none;
      z-index: 999;
    }
    .toast.error { background: var(--red); }
    .toast.show { opacity: 1; transform: translateY(0); }

    /* Seed button section */
    .danger-zone {
      background: rgba(200,64,64,0.06);
      border: 1px dashed rgba(200,64,64,0.3);
      border-radius: var(--radius);
      padding: 16px;
      margin-top: 24px;
    }
    .danger-zone h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; color: var(--red); margin-bottom: 10px; }
  </style>
</head>
<body>

<header class="header">
  <div>
    <div class="header-title">⚙️ Admin Penca Mundial</div>
    <div class="header-sub">saltouruguayserver.com — Solo vos podés ver esto</div>
  </div>
  <div class="header-actions">
    <a href="/penca" style="text-decoration:none">
      <button class="btn btn-ghost btn-sm">Ver como jugador →</button>
    </a>
  </div>
</header>

<div class="container">
  <main>

    <!-- Stats -->
    <div class="stats-bar">
      <div class="stat-card">
        <div class="stat-value">{matches.length}</div>
        <div class="stat-label">Partidos cargados</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style={`color:${pending.length > 0 ? 'var(--red)' : 'var(--green-light)'}`}>{pending.length}</div>
        <div class="stat-label">Resultados pendientes</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{withResult.length}</div>
        <div class="stat-label">Resultados cargados</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{leaderboard.length}</div>
        <div class="stat-label">Jugadores activos</div>
      </div>
    </div>

    <!-- Alerta pendientes -->
    {pending.length > 0 && (
      <div class="alert">
        <span class="count">{pending.length}</span>
        <span>
          {pending.length === 1
            ? "partido ya jugado sin resultado cargado. ¡Cargalo para que los puntos se actualicen!"
            : "partidos ya jugados sin resultado cargado. ¡Cargalos para actualizar los puntos!"}
        </span>
      </div>
    )}

    <!-- Campeón -->
    <div class="champion-section">
      <h2>🏆 Definir campeón del torneo</h2>
      <div class="champion-controls">
        <input
          class="champion-input"
          type="text"
          id="champion-team-input"
          placeholder="Ej: ARG, BRA, URU..."
          maxlength="10"
        />
        <button class="btn btn-gold" onclick="setChampion()">
          Confirmar campeón (+10 pts a acertadores)
        </button>
        <button class="btn btn-ghost btn-sm" onclick="lockChampionPicks()">
          🔒 Cerrar picks de campeón
        </button>
      </div>
      <p style="font-size:12px;color:var(--text-muted);margin-top:10px">
        ⚠️ Esto suma 10 puntos a todos los que eligieron ese equipo. Solo hacelo una vez al finalizar el torneo.
      </p>
    </div>

    <!-- Partidos por fase -->
    {Object.entries(matchesByPhase).map(([phase, phaseMatches]) => (
      phaseMatches.length > 0 && (
        <>
          <div class="section-title">
            {PHASE_LABELS[phase]}
            <span style="font-size:11px">{phaseMatches.filter(m => m.result !== null).length}/{phaseMatches.length} resultados cargados</span>
          </div>
          {phaseMatches.map(match => {
            const isPending = match.result === null && Date.now() >= match.kickoff;
            const isDone = match.result !== null;
            return (
              <div class={`match-row ${isPending ? "pending-result" : ""} ${isDone ? "done" : ""}`} id={`row-${match.id}`}>
                <div class="match-info">
                  <div class="match-teams-text">
                    <span>{match.homeFlag} {match.home}</span>
                    <span style="color:var(--text-muted);font-size:13px">vs</span>
                    <span>{match.away} {match.awayFlag}</span>
                  </div>
                  <div class="match-kick">
                    {new Date(match.kickoff).toLocaleString("es-UY", { weekday: "short", day: "2-digit", month: "short", hour: "2-digit", minute: "2-digit" })}
                  </div>
                  {isDone && (
                    <span class="result-badge">{match.homeScore} - {match.awayScore}</span>
                  )}
                </div>
                <div class="score-form">
                  <input
                    class="score-in"
                    type="number"
                    min="0"
                    max="20"
                    id={`hs-${match.id}`}
                    value={match.homeScore ?? ""}
                    placeholder="0"
                  />
                  <span class="score-sep">-</span>
                  <input
                    class="score-in"
                    type="number"
                    min="0"
                    max="20"
                    id={`as-${match.id}`}
                    value={match.awayScore ?? ""}
                    placeholder="0"
                  />
                  <button
                    class={`btn btn-sm ${isDone ? "btn-ghost" : "btn-primary"}`}
                    onclick={`submitResult('${match.id}')`}
                    id={`submit-${match.id}`}
                  >
                    {isDone ? "Editar" : "Cargar"}
                  </button>
                </div>
              </div>
            );
          })}
        </>
      )
    ))}

    <!-- Zona de peligro -->
    <div class="danger-zone">
      <h3>⚠️ Zona de administración</h3>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-ghost btn-sm" onclick="seedMatches()">
          Poblar partidos de grupos (seed inicial)
        </button>
        <button class="btn btn-danger btn-sm" onclick="if(confirm('¿Seguro? Esto no se puede deshacer.')) resetScores()">
          Resetear todos los puntajes
        </button>
      </div>
      <p style="font-size:11px;color:var(--text-muted);margin-top:8px">El seed solo es necesario la primera vez. Los partidos de eliminatorias se agregan manualmente desde la API cuando se conozcan los cruces.</p>
    </div>

  </main>

  <!-- Sidebar: Leaderboard en tiempo real -->
  <aside>
    <div class="sidebar-card">
      <div class="sidebar-header">🏅 Tabla actual</div>
      {leaderboard.length === 0 && (
        <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px">
          Todavía no hay puntajes.
        </div>
      )}
      {leaderboard.map(entry => (
        <div class="lb-row">
          <div class={`lb-rank ${entry.rank === 1 ? "top1" : entry.rank === 2 ? "top2" : entry.rank === 3 ? "top3" : ""}`}>
            {entry.rank === 1 ? "🥇" : entry.rank === 2 ? "🥈" : entry.rank === 3 ? "🥉" : `#${entry.rank}`}
          </div>
          <div class="lb-name" title={entry.username}>{entry.username}</div>
          <div class="lb-score">{entry.score} <span style="font-size:11px;color:var(--text-muted)">pts</span></div>
        </div>
      ))}
    </div>
  </aside>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script define:vars={{ adminSecret }}>
  function showToast(msg, isError = false) {
    const t = document.getElementById("toast");
    t.textContent = msg;
    t.className = `toast${isError ? " error" : ""} show`;
    setTimeout(() => t.classList.remove("show"), 3000);
  }

  async function adminFetch(url, body) {
    const res = await fetch(url, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-admin-secret": adminSecret,
      },
      body: JSON.stringify(body),
    });
    return res.json();
  }

  async function submitResult(matchId) {
    const hs = document.getElementById(`hs-${matchId}`)?.value;
    const as = document.getElementById(`as-${matchId}`)?.value;

    if (hs === "" || as === "") {
      showToast("Ingresá ambos marcadores", true);
      return;
    }

    const btn = document.getElementById(`submit-${matchId}`);
    btn.disabled = true;
    btn.textContent = "...";

    try {
      const data = await adminFetch("/api/penca/admin/result", {
        matchId,
        homeScore: Number(hs),
        awayScore: Number(as),
      });

      if (data.ok) {
        showToast(`✓ Resultado cargado — los puntos se actualizaron`);
        const row = document.getElementById(`row-${matchId}`);
        row?.classList.remove("pending-result");
        row?.classList.add("done");
        btn.textContent = "Editar";
        btn.className = "btn btn-sm btn-ghost";
      } else {
        showToast(data.error || "Error al cargar resultado", true);
        btn.textContent = "Cargar";
      }
    } catch {
      showToast("Error de conexión", true);
      btn.textContent = "Cargar";
    }

    btn.disabled = false;
  }

  async function setChampion() {
    const teamId = document.getElementById("champion-team-input")?.value?.trim().toUpperCase();
    if (!teamId) { showToast("Ingresá el ID del equipo", true); return; }

    if (!confirm(`¿Confirmar a ${teamId} como campeón? Esto suma 10 pts a todos los que lo eligieron.`)) return;

    const data = await adminFetch("/api/penca/admin/champion", { teamId });
    if (data.ok) {
      showToast(`🏆 ${teamId} definido como campeón. Puntos sumados.`);
    } else {
      showToast(data.error || "Error", true);
    }
  }

  async function lockChampionPicks() {
    if (!confirm("¿Cerrar las predicciones de campeón? Los jugadores ya no podrán cambiarlas.")) return;
    const data = await adminFetch("/api/penca/admin/champion", { action: "lock" });
    if (data.ok) {
      showToast("🔒 Picks de campeón cerrados.");
    } else {
      showToast(data.error || "Error", true);
    }
  }

  async function seedMatches() {
    if (!confirm("¿Poblar los partidos de grupos? Solo hacelo si Redis está vacío.")) return;
    const data = await adminFetch("/api/penca/admin/seed", {});
    if (data.ok) {
      showToast("✓ Partidos cargados. Recargá la página.");
      setTimeout(() => location.reload(), 1500);
    } else {
      showToast(data.error || "Error al hacer seed", true);
    }
  }

  async function resetScores() {
    // Implementá este endpoint si lo necesitás — borra penca:scores del ZSet
    showToast("Endpoint no implementado aún", true);
  }

  window.submitResult = submitResult;
  window.setChampion = setChampion;
  window.lockChampionPicks = lockChampionPicks;
  window.seedMatches = seedMatches;
  window.resetScores = resetScores;
</script>

</body>
</html>
