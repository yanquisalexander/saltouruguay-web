---
export const prerender = false;

// Esta página lee los puntajes en tiempo real de la API
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Overlay Leaderboard · Liga Fortnite</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Barlow+Condensed:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      background: transparent !important;
      font-family: 'Barlow Condensed', sans-serif;
      width: 600px;
      min-height: 100vh;
      overflow: hidden;
    }

    #controls {
      display: flex;
      gap: 10px;
      justify-content: center;
      padding: 14px;
      background: rgba(10,10,20,0.7);
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .ctrl-btn {
      padding: 10px 20px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 13px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .ctrl-btn:hover { transform: scale(1.05); }
    .ctrl-btn:active { transform: scale(0.97); }

    .btn-reveal {
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: #1a0e00;
    }

    .btn-reset {
      background: rgba(255,255,255,0.15);
      color: white;
      border: 1px solid rgba(255,255,255,0.2);
    }

    #header {
      padding: 16px 24px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: linear-gradient(135deg, rgba(15,15,30,0.95), rgba(25,20,50,0.95));
      border-bottom: 2px solid rgba(245,158,11,0.4);
      backdrop-filter: blur(10px);
    }

    #header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    #header-icon {
      font-size: 28px;
      line-height: 1;
    }

    #header-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: rgba(255,255,255,0.4);
      line-height: 1;
    }

    #header-division {
      font-size: 22px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #fff;
      line-height: 1.1;
    }

    #live-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      background: rgba(239,68,68,0.2);
      border: 1px solid rgba(239,68,68,0.4);
      border-radius: 20px;
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #ef4444;
    }

    #live-dot {
      width: 7px;
      height: 7px;
      background: #ef4444;
      border-radius: 50%;
      animation: pulse 1.2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.8); }
    }

    #div-selector {
      display: flex;
      gap: 6px;
      padding: 8px 24px;
      background: rgba(10,10,20,0.7);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .div-pill {
      padding: 6px 14px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      border-radius: 20px;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.5);
      transition: all 0.2s;
    }

    .div-pill.active {
      background: rgba(245,158,11,0.2);
      border-color: rgba(245,158,11,0.5);
      color: #f59e0b;
    }

    #list-container {
      background: rgba(10,10,20,0.88);
      backdrop-filter: blur(10px);
    }

    .player-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 24px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      opacity: 0;
      transform: translateX(-20px);
      transition: background 0.2s;
    }

    .player-row.visible {
      animation: slideIn 0.4s forwards;
    }

    @keyframes slideIn {
      to { opacity: 1; transform: translateX(0); }
    }

    .player-row:hover {
      background: rgba(255,255,255,0.03);
    }

    .rank-num {
      font-size: 15px;
      font-weight: 900;
      color: rgba(255,255,255,0.25);
      width: 28px;
      text-align: center;
      flex-shrink: 0;
    }

    .player-name {
      flex: 1;
      font-size: 18px;
      font-weight: 700;
      color: rgba(255,255,255,0.9);
      letter-spacing: 0.5px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .player-points {
      font-size: 22px;
      font-weight: 900;
      color: rgba(255,255,255,0.7);
      letter-spacing: 1px;
      flex-shrink: 0;
    }

    #podio-divider {
      display: none;
      align-items: center;
      gap: 12px;
      padding: 10px 24px;
      background: rgba(245,158,11,0.08);
      border-top: 1px solid rgba(245,158,11,0.3);
      border-bottom: 1px solid rgba(245,158,11,0.3);
    }

    #podio-divider.visible {
      display: flex;
    }

    #podio-divider span {
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: rgba(245,158,11,0.6);
      white-space: nowrap;
    }

    #podio-divider hr {
      flex: 1;
      border: none;
      border-top: 1px solid rgba(245,158,11,0.2);
    }

    #podio-container {
      background: rgba(10,10,20,0.92);
      backdrop-filter: blur(10px);
    }

    .podio-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 24px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      opacity: 0;
      transform: scale(0.95) translateY(10px);
      position: relative;
      overflow: hidden;
    }

    .podio-row.reveal-3,
    .podio-row.reveal-2 {
      animation: revealPodio 0.6s forwards cubic-bezier(0.34,1.56,0.64,1);
    }

    .podio-row.reveal-1 {
      animation: revealPodio 0.7s forwards cubic-bezier(0.34,1.56,0.64,1);
    }

    @keyframes revealPodio {
      0% { opacity: 0; transform: scale(0.9) translateY(15px); }
      60% { opacity: 1; transform: scale(1.02) translateY(-3px); }
      100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    .podio-row.reveal-1::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(245,158,11,0.08), transparent);
      animation: shimmer 2s 0.3s infinite;
    }

    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    .podio-medal {
      font-size: 26px;
      flex-shrink: 0;
      filter: drop-shadow(0 0 8px rgba(255,255,255,0.3));
    }

    .podio-name {
      flex: 1;
      font-size: 22px;
      font-weight: 900;
      letter-spacing: 1px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      position: relative;
      z-index: 1;
    }

    .podio-points {
      font-size: 30px;
      font-weight: 900;
      letter-spacing: 1px;
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }

    .podio-row.reveal-1 .podio-name,
    .podio-row.reveal-1 .podio-points {
      color: #fbbf24;
      text-shadow: 0 0 20px rgba(251,191,36,0.5);
    }

    .podio-row.reveal-2 .podio-name,
    .podio-row.reveal-2 .podio-points {
      color: #e2e8f0;
    }

    .podio-row.reveal-3 .podio-name,
    .podio-row.reveal-3 .podio-points {
      color: #cd7c3a;
    }

    #loading {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      color: rgba(255,255,255,0.3);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 3px;
      background: rgba(10,10,20,0.9);
    }
  </style>
</head>

<body>

  <div id="div-selector">
    <button class="div-pill active" onclick="setDiv('clasificatoria', this)">🛡️ Clasificatoria</button>
    <button class="div-pill" onclick="setDiv('semi_profesional', this)">⚡ Semi Pro</button>
    <button class="div-pill" onclick="setDiv('profesional', this)">👑 Profesional</button>
  </div>

  <div id="header">
    <div id="header-left">
      <div id="header-icon">🛡️</div>
      <div>
        <div id="header-title">Liga Fortnite · ACRECONRE</div>
        <div id="header-division">Clasificatoria</div>
      </div>
    </div>

    <div id="live-badge">
      <div id="live-dot"></div>
      En vivo
    </div>
  </div>

  <div id="list-container">
    <div id="loading">Cargando...</div>
    <div id="player-list"></div>
  </div>

  <div id="podio-divider">
    <hr />
    <span>⭐ Top 3 ⭐</span>
    <hr />
  </div>

  <div id="podio-container">
    <div id="podio-list"></div>
  </div>

  <div id="controls">
    <button class="ctrl-btn btn-reveal" onclick="revealNext()">▶ Revelar siguiente</button>
    <button class="ctrl-btn btn-reset" onclick="resetReveal()">↺ Reiniciar</button>
  </div>

  <script>
    const DIVISIONS = {
      clasificatoria: {
        label: "Clasificatoria",
        icon: "🛡️",
      },
      semi_profesional: {
        label: "Semi Profesional",
        icon: "⚡",
      },
      profesional: {
        label: "Profesional",
        icon: "👑",
      },
    };

    let currentDiv = "clasificatoria";
    let allPlayers = [];
    let podioRevealed = 0;

    async function loadData() {
      const loading = document.getElementById("loading");
      const playerList = document.getElementById("player-list");
      const podioList = document.getElementById("podio-list");
      const podioDivider = document.getElementById("podio-divider");

      loading.style.display = "flex";
      loading.textContent = "Cargando...";
      playerList.innerHTML = "";
      podioList.innerHTML = "";
      podioDivider.classList.remove("visible");
      podioRevealed = 0;

      try {
        const [playersRes, scoresRes] = await Promise.all([
          fetch("/api/fortnite-league/players"),
          fetch("/api/fortnite-league/scores"),
        ]);

        if (!playersRes.ok || !scoresRes.ok) {
          throw new Error("Error en la respuesta de la API");
        }

        const playersData = await playersRes.json();
        const scoresData = await scoresRes.json();

        const players = playersData.players ?? [];
        const scores = scoresData.scores ?? [];

        const scoresMap = {};

        scores.forEach((score) => {
          scoresMap[score.inscriptionId] = score;
        });

        allPlayers = players
          .filter((player) => player.division === currentDiv)
          .map((player) => ({
            id: player.id,
            name: player.discordUsername || "Sin nombre",
            total: scoresMap[player.id]?.total ?? 0,
          }))
          .sort((a, b) => b.total - a.total);

        loading.style.display = "none";
        renderList();
      } catch (error) {
        console.error(error);
        loading.textContent = "Error al cargar";
      }
    }

    function renderList() {
      const list = document.getElementById("player-list");
      list.innerHTML = "";

      if (allPlayers.length === 0) {
        list.innerHTML = `
          <div style="padding:30px;text-align:center;color:rgba(255,255,255,0.2);font-size:12px;letter-spacing:2px;text-transform:uppercase;">
            Sin jugadores
          </div>
        `;
        return;
      }

      const rest = allPlayers.slice(3);

      rest.forEach((player, index) => {
        const rank = index + 4;
        const row = document.createElement("div");

        row.className = "player-row";
        row.style.animationDelay = `${index * 80}ms`;

        row.innerHTML = `
          <span class="rank-num">${rank}</span>
          <span class="player-name">${player.name}</span>
          <span class="player-points">${player.total} pts</span>
        `;

        list.appendChild(row);

        requestAnimationFrame(() => {
          row.classList.add("visible");
        });
      });
    }

    function revealNext() {
      if (podioRevealed >= 3) return;

      podioRevealed++;

      const podioDivider = document.getElementById("podio-divider");
      const podioList = document.getElementById("podio-list");

      const pos = 4 - podioRevealed;
      const player = allPlayers[pos - 1];

      if (!player) {
        podioRevealed--;
        return;
      }

      if (podioRevealed === 1) {
        podioDivider.classList.add("visible");
      }

      const medals = {
        1: "🥇",
        2: "🥈",
        3: "🥉",
      };

      const row = document.createElement("div");
      row.className = `podio-row reveal-${pos}`;

      row.innerHTML = `
        <span class="podio-medal">${medals[pos]}</span>
        <span class="podio-name">${player.name}</span>
        <span class="podio-points">${player.total} pts</span>
      `;

      podioList.insertBefore(row, podioList.firstChild);
    }

    function resetReveal() {
      podioRevealed = 0;
      document.getElementById("podio-list").innerHTML = "";
      document.getElementById("podio-divider").classList.remove("visible");
    }

    window.setDiv = function(divId, button) {
      if (!DIVISIONS[divId]) return;

      currentDiv = divId;

      document.querySelectorAll(".div-pill").forEach((element) => {
        element.classList.remove("active");
      });

      button.classList.add("active");

      document.getElementById("header-division").textContent = DIVISIONS[divId].label;
      document.getElementById("header-icon").textContent = DIVISIONS[divId].icon;

      resetReveal();
      loadData();
    };

    loadData();

    setInterval(() => {
      if (podioRevealed === 0) {
        loadData();
      }
    }, 30000);
  </script>
</body>
</html>