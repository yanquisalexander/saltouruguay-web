---
import Layout from "@/layouts/Layout.astro";
import { client, pool } from "@/db/client";
import {
  FortniteLeagueInscriptionsTable,
  FortniteLeagueScoresTable,
} from "@/db/schema";

export const prerender = false;

try {
  await pool.query(`
    CREATE TABLE IF NOT EXISTS fortnite_league_scores (
      id SERIAL PRIMARY KEY,
      inscription_id INTEGER NOT NULL REFERENCES fortnite_league_inscriptions(id) ON DELETE CASCADE,
      set1 INTEGER NOT NULL DEFAULT 0,
      set2 INTEGER NOT NULL DEFAULT 0,
      set3 INTEGER NOT NULL DEFAULT 0,
      total INTEGER NOT NULL DEFAULT 0,
      created_at TIMESTAMP NOT NULL DEFAULT current_timestamp,
      updated_at TIMESTAMP NOT NULL DEFAULT current_timestamp,
      UNIQUE(inscription_id)
    )
  `);
} catch (e) {
  console.error("ERROR creando/verificando tabla fortnite_league_scores:", e);
}

let players = [];
let scores = [];

try {
  players = await client
    .select()
    .from(FortniteLeagueInscriptionsTable)
    .execute();
  scores = await client.select().from(FortniteLeagueScoresTable).execute();
} catch (e) {
  console.error("ERROR cargando jugadores o puntajes:", e);
  throw e;
}

const scoresMap = Object.fromEntries(scores.map((s) => [s.inscriptionId, s]));

const DIVISIONALES = [
  { id: "clasificatoria", label: "Clasificatoria", icon: "🛡️" },
  { id: "semi_profesional", label: "Semi Profesional", icon: "⚡" },
  { id: "profesional", label: "Profesional", icon: "👑" },
];

---

<Layout
  title="Admin · Tabla de Puntos | Liga Fortnite"
  description="Panel de administración de puntajes de la Liga Fortnite."
>
  <div
    id="page-content"
    class="hidden flex-col items-center justify-start min-h-[90vh] py-20 px-4"
  >
    <div class="w-full max-w-6xl mb-8">
      <a
        href="/liga-fortnite"
        class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] opacity-40 hover:opacity-100 transition-opacity mb-8"
      >
        ← Volver a la Liga
      </a>

      <p
        class="text-xs font-bold uppercase tracking-[0.25em] opacity-40 mb-2 mt-6"
      >
        Panel de Administración
      </p>
      <div class="flex items-end justify-between gap-4 flex-wrap">
        <div>
          <h1
            class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none mb-2"
          >
            Tabla de <span class="opacity-40 font-light">Puntos</span>
          </h1>
          <p
            class="text-[10px] font-bold uppercase tracking-[0.15em] opacity-30 mt-3"
          >
            Los cambios se guardan al hacer clic en Guardar Todo
          </p>
        </div>

        <!-- BOTÓN GUARDAR GENERAL -->
        <button
          id="save-all-btn"
          class="px-6 py-3 text-[10px] font-black uppercase tracking-[0.2em] rounded-xl border border-amber-500/40 bg-amber-500/10 text-amber-400 hover:bg-amber-500/20 hover:border-amber-500/60 active:scale-95 transition-all duration-200 cursor-pointer whitespace-nowrap"
        >
          💾 Guardar Todo
        </button>
      </div>
    </div>

    <div class="w-full max-w-6xl space-y-16">
      {
        DIVISIONALES.map((div) => {
          const divPlayers = players
            .filter((p) => p.division === div.id)
            .sort((a, b) => {
              const sa = scoresMap[a.id]?.total ?? 0;
              const sb = scoresMap[b.id]?.total ?? 0;
              return sb - sa;
            });

          return (
            <div>
              <div class="flex items-center gap-4 mb-6">
                <span class="text-2xl">{div.icon}</span>
                <h2 class="text-xl font-black uppercase tracking-tight">
                  {div.label}
                </h2>
                <span class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-30">
                  {divPlayers.length} jugadores
                </span>
              </div>

              {divPlayers.length === 0 ? (
                <div class="w-full py-10 rounded-2xl border border-current/10 bg-current/[0.01] text-center">
                  <p class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-30">
                    Sin jugadores en esta divisional
                  </p>
                </div>
              ) : (
                <div class="w-full rounded-2xl border border-current/10 overflow-hidden">
                  <div class="grid grid-cols-[2rem_1fr_8rem_8rem_8rem_8rem] gap-0 px-4 py-3 border-b border-current/10 bg-current/[0.03]">
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] opacity-40">
                      #
                    </p>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] opacity-40">
                      Jugador
                    </p>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] opacity-40 text-center">
                      Partida 1
                    </p>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] opacity-40 text-center">
                      Partida 2
                    </p>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] opacity-40 text-center">
                      Partida 3
                    </p>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] opacity-40 text-center">
                      Total
                    </p>
                  </div>

                  {divPlayers.map((player, idx) => {
                    const score = scoresMap[player.id];

                    return (
                      <div
                        data-division={div.id}
                        data-player-id={player.id}
                        class={`grid grid-cols-[2rem_1fr_8rem_8rem_8rem_8rem] gap-0 px-4 py-3 items-center border-b border-current/10 last:border-0 transition-colors ${idx === 0 ? "bg-amber-500/5" : "hover:bg-current/[0.02]"}`}
                      >
                        <p
                          class={`text-sm font-black ${idx === 0 ? "text-amber-400" : idx === 1 ? "opacity-60" : idx === 2 ? "opacity-40" : "opacity-20"}`}
                        >
                          {idx + 1}
                        </p>

                        <div class="min-w-0 pr-2">
                          <p class="text-sm font-bold truncate">
                            {player.discordUsername}
                          </p>
                          <p class="text-[9px] opacity-40 truncate">
                            ({player.epicId}) · {player.platform}
                          </p>
                        </div>

                        <div class="px-1">
                          <input
                            type="number"
                            min="0"
                            max="999"
                            id={`set1-${player.id}`}
                            value={score?.set1 ?? 0}
                            class="w-full px-2 py-1.5 rounded-lg border border-current/10 bg-white text-sm font-bold text-black text-center focus:outline-none focus:border-amber-500/50 transition-all duration-200"
                            oninput={`calcTotal(${player.id})`}
                          />
                        </div>

                        <div class="px-1">
                          <input
                            type="number"
                            min="0"
                            max="999"
                            id={`set2-${player.id}`}
                            value={score?.set2 ?? 0}
                            class="w-full px-2 py-1.5 rounded-lg border border-current/10 bg-white text-sm font-bold text-black text-center focus:outline-none focus:border-amber-500/50 transition-all duration-200"
                            oninput={`calcTotal(${player.id})`}
                          />
                        </div>

                        <div class="px-1">
                          <input
                            type="number"
                            min="0"
                            max="999"
                            id={`set3-${player.id}`}
                            value={score?.set3 ?? 0}
                            class="w-full px-2 py-1.5 rounded-lg border border-current/10 bg-white text-sm font-bold text-black text-center focus:outline-none focus:border-amber-500/50 transition-all duration-200"
                            oninput={`calcTotal(${player.id})`}
                          />
                        </div>

                        <div class="text-center px-1">
                          <span
                            id={`total-${player.id}`}
                            class="text-lg font-black text-amber-400"
                          >
                            {score?.total ?? 0}
                          </span>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })
      }
    </div>

    <div class="pt-16 opacity-20 mt-8">
      <p class="text-[10px] font-bold uppercase tracking-[0.15em]">
        Asociación de Creadores de Contenido de la Región · Admin
      </p>
    </div>
  </div>

  <div
    id="no-access"
    class="flex flex-col items-center justify-center min-h-[90vh] gap-4"
  >
    <p class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-30">
      Verificando acceso...
    </p>
  </div>
</Layout>

<script>
  import { $ } from "@/lib/dom-selector";
  import { getSessionClient } from "@/lib/auth-client";

  const init = async () => {
    const session = await getSessionClient();

    const isAdmin = session?.user?.isAdmin ?? false;

    console.log({ session, isAdmin });

    if (isAdmin) {
      $("#page-content")?.classList.replace("hidden", "flex");
      $("#no-access")?.classList.add("hidden");
    } else {
      window.location.href = "/liga-fortnite";
    }

    const calcTotal = (playerId: number) => {
      const s1 =
        parseInt(($(`#set1-${playerId}`) as HTMLInputElement)?.value || "0") || 0;
      const s2 =
        parseInt(($(`#set2-${playerId}`) as HTMLInputElement)?.value || "0") || 0;
      const s3 =
        parseInt(($(`#set3-${playerId}`) as HTMLInputElement)?.value || "0") || 0;

      const $total = $(`#total-${playerId}`);
      if ($total) $total.textContent = String(s1 + s2 + s3);
    };

    const saveScore = async (playerId: number) => {
      const s1 = parseInt(($(`#set1-${playerId}`) as HTMLInputElement)?.value || "0") || 0;
      const s2 = parseInt(($(`#set2-${playerId}`) as HTMLInputElement)?.value || "0") || 0;
      const s3 = parseInt(($(`#set3-${playerId}`) as HTMLInputElement)?.value || "0") || 0;

      return fetch("/api/fortnite-league/scores", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ inscriptionId: playerId, set1: s1, set2: s2, set3: s3 }),
      });
    };

    const saveAll = async () => {
      const $btn = document.getElementById("save-all-btn") as HTMLButtonElement;
      if (!$btn) return;

      const original = $btn.textContent;
      $btn.textContent = "Guardando...";
      $btn.disabled = true;

      const rows = document.querySelectorAll<HTMLElement>("[data-player-id]");
      const promises: Promise<Response>[] = [];

      rows.forEach((row) => {
        const playerId = Number(row.dataset.playerId);
        if (!playerId) return;
        promises.push(saveScore(playerId));
      });

      try {
        const results = await Promise.all(promises);
        const allOk = results.every((r) => r.ok);

        if (allOk) {
          $btn.textContent = "✓ Todo guardado";
          $btn.classList.add("text-green-400", "border-green-500/30", "bg-green-500/10");
          $btn.classList.remove("text-amber-400", "border-amber-500/40", "bg-amber-500/10");
        } else {
          $btn.textContent = "⚠ Hubo errores";
          $btn.classList.add("text-red-400", "border-red-500/30", "bg-red-500/10");
          $btn.classList.remove("text-amber-400", "border-amber-500/40", "bg-amber-500/10");
        }
      } catch {
        $btn.textContent = "⚠ Error de red";
        $btn.classList.add("text-red-400", "border-red-500/30", "bg-red-500/10");
        $btn.classList.remove("text-amber-400", "border-amber-500/40", "bg-amber-500/10");
      }

      setTimeout(() => {
        $btn.textContent = original;
        $btn.classList.remove(
          "text-green-400", "border-green-500/30", "bg-green-500/10",
          "text-red-400", "border-red-500/30", "bg-red-500/10"
        );
        $btn.classList.add("text-amber-400", "border-amber-500/40", "bg-amber-500/10");
        $btn.disabled = false;
      }, 2000);
    };

    document.getElementById("save-all-btn")?.addEventListener("click", saveAll);

    (window as any).calcTotal = calcTotal;
  };

  document.addEventListener("astro:page-load", init);
</script>
