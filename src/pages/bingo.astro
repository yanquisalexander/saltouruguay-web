---
import Layout from "@/layouts/Layout.astro";
import { getSession } from "auth-astro/server";

const authSession = await getSession(Astro.request);
const sessionId = Astro.url.searchParams.get("session") ?? "";
const isLoggedIn = !!authSession?.user;
const username = authSession?.user?.name ?? authSession?.user?.email ?? null;
const initials = username?.substring(0, 2).toUpperCase() ?? "";
---

<Layout
  title="Bingo — Salto Uruguay Server"
  description="Jugá al bingo en vivo con el streamer en Salto Uruguay"
  hideHeader
  hideFooter
  mainClassname="px-4 sm:px-6 pt-6 pb-20"
>
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-[url(/bg.svg)] opacity-30"></div>
    <div
      class="absolute top-0 right-0 w-[600px] h-[600px] bg-electric-violet-900/20 blur-[150px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-amber-900/10 blur-[120px] rounded-full"
    >
    </div>
  </div>

  <div class="max-w-md mx-auto min-h-screen flex flex-col">
    <div class="text-center mb-6">
      <h1
        class="font-anton text-6xl bg-linear-to-r from-amber-400 to-yellow-300 bg-clip-text text-transparent tracking-wide leading-none"
      >
        BINGO
      </h1>
      <p
        class="text-white/30 font-rubik text-xs uppercase tracking-[0.2em] mt-1"
      >
        saltouruguayserver.com
      </p>
    </div>

    {
      !sessionId && (
        <div class="bg-white/5 border border-red-500/40 rounded-2xl p-8 text-center max-w-sm mx-auto w-full mt-8">
          <div class="text-4xl mb-3">⚠️</div>
          <h2 class="font-anton text-xl text-red-400 mb-2">Sesión inválida</h2>
          <p class="text-white/40 font-rubik text-sm">
            El link que usaste no tiene una sesión de bingo válida. Pedile el
            link correcto al streamer en el chat.
          </p>
        </div>
      )
    }

    {
      sessionId && !isLoggedIn && (
        <div class="bg-white/5 border border-electric-violet-500/30 rounded-2xl p-8 text-center max-w-sm mx-auto w-full mt-8">
          <h2 class="font-anton text-2xl bg-linear-to-r from-amber-400 to-yellow-300 bg-clip-text text-transparent mb-3">
            ¡Iniciá sesión para jugar!
          </h2>
          <p class="text-white/40 font-rubik text-sm mb-6">
            Necesitás una cuenta en saltouruguayserver.com para reclamar tu
            cartón de bingo.
          </p>
          <a
            href={`/api/auth/signin?callbackUrl=/bingo?session=${sessionId}`}
            class="inline-block bg-linear-to-br from-electric-violet-500 to-fuchsia-600 text-white font-anton text-lg tracking-wider px-10 py-3 rounded-full shadow-lg shadow-electric-violet-500/40 hover:shadow-xl hover:shadow-electric-violet-500/60 hover:-translate-y-0.5 transition-all duration-200"
          >
            🎮 Iniciar sesión
          </a>
        </div>
      )
    }

    {
      sessionId && isLoggedIn && (
        <div id="game-screen" class="flex flex-col gap-3">
          <div class="flex items-center gap-3 bg-white/5 rounded-xl px-4 py-3 border border-white/5">
            <div class="w-10 h-10 rounded-full bg-electric-violet-500 flex items-center justify-center font-rubik font-black text-sm text-white flex-shrink-0">
              {initials}
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-rubik font-bold text-sm text-white truncate">
                {username}
              </div>
              <div class="font-rubik text-[11px] text-white/30">
                Sesión: {sessionId}
              </div>
            </div>
          </div>

          <div
            id="win-banner"
            class="hidden bg-linear-to-br from-green-950/80 to-emerald-950/80 border-2 border-green-500 rounded-2xl p-6 text-center"
          >
            <div class="font-anton text-3xl text-green-400">🏆 ¡BINGO!</div>
            <div id="win-sub" class="font-rubik text-green-200 text-sm mt-2" />
          </div>

          <div
            id="other-banner"
            class="hidden bg-white/5 border border-red-500/40 rounded-2xl p-4 text-center"
          >
            <p class="font-rubik font-bold text-red-400">¡Otro jugador ganó!</p>
            <small id="other-name" class="text-white/40 text-xs" />
          </div>

          <div class="bg-white/5 rounded-xl px-4 py-3 border border-white/5 flex items-center gap-4">
            <div>
              <div class="font-rubik text-[10px] text-white/30 uppercase tracking-widest mb-1">
                Número actual
              </div>
              <div
                id="curr-num"
                class="w-14 h-14 rounded-full bg-linear-to-br from-orange-400 to-amber-500 flex items-center justify-center font-anton text-xl text-stone-900 shadow-lg shadow-orange-500/30 flex-shrink-0 transition-all duration-300"
              >
                —
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-rubik text-[10px] text-white/30 uppercase tracking-widest mb-1">
                Anteriores
              </div>
              <div id="hist-row" class="flex gap-1.5 flex-wrap" />
            </div>
          </div>

          <div id="card-area">
            <div class="bg-white/5 rounded-2xl border border-white/5 p-10 text-center">
              <div class="w-8 h-8 border-2 border-electric-violet-500/30 border-t-electric-violet-500 rounded-full animate-spin mx-auto mb-4" />
              <p class="font-rubik text-sm text-white/40">
                Obteniendo tu cartón...
              </p>
            </div>
          </div>

          <p class="font-rubik text-[11px] text-white/30 text-center">
            Tocá los números que vayan saliendo para marcarlos ✓
          </p>
        </div>
      )
    }
  </div>
</Layout>

<style>
  @reference "../assets/styles/global.css";

  #win-banner.show {
    display: block;
  }
  #other-banner.show {
    display: block;
  }

  @keyframes win-glow {
    from {
      box-shadow: 0 0 20px rgba(34, 197, 94, 0.3);
    }
    to {
      box-shadow: 0 0 50px rgba(34, 197, 94, 0.8);
    }
  }

  #win-banner.show {
    animation: win-glow 1s ease-in-out infinite alternate;
  }

  @keyframes ball-pop {
    0% {
      transform: scale(0.6);
    }
    70% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1);
    }
  }

  .ball-pop {
    animation: ball-pop 0.45s ease;
  }

  @keyframes win-cell-pulse {
    from {
      box-shadow: 0 0 6px rgba(34, 197, 94, 0.4);
      background: linear-gradient(to bottom right, #fbbf24, #f97316);
      color: #1c1917;
    }
    to {
      box-shadow: 0 0 24px rgba(34, 197, 94, 0.9);
      background: #22c55e;
      color: #fff;
    }
  }

  .cell.win-cell {
    animation: win-cell-pulse 0.7s ease infinite alternate;
  }

  .hist-chip {
    @apply bg-white/[0.07] rounded px-1.5 py-0.5 text-[11px] font-rubik font-bold text-orange-300;
  }
</style>

<script>
  import { $, $$ } from "@/lib/dom-selector";
  import { getSessionClient } from "@/lib/auth-client";

  const sessionId = new URLSearchParams(window.location.search).get("session");

  document.addEventListener("astro:page-load", async () => {
    if (!sessionId) return;
    const session = await getSessionClient();

    const username =
      session?.user?.username || session?.user?.email || "Jugador";

    window.__bingoState = null;
    const API = "/api/bingo";
    let myCard = null;
    let marked = new Set(["FREE"]);
    let lastDrawn = 0;
    let cardRendered = false;

    async function claimCard() {
      const res = await fetch(`${API}/claim`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ session: sessionId }),
      });
      const data = await res.json();
      if (!res.ok) {
        const area = $("#card-area");
        if (area) {
          area.innerHTML = `<div class="bg-white/5 border border-red-500/40 rounded-2xl p-8 text-center"><h2 class="font-anton text-xl text-red-400 mb-2">Error</h2><p class="text-white/40 text-sm">${data.error}</p></div>`;
        }
        return;
      }
      myCard = data.card;
      const saved = sessionStorage.getItem("bingo-marked-" + sessionId);
      if (saved) {
        try {
          marked = new Set(JSON.parse(saved));
        } catch {}
      }
      marked.add("FREE");
      renderCard();
      cardRendered = true;
    }

    function renderCard() {
      const area = $("#card-area");
      if (!area) return;
      area.innerHTML = `
      <div class="bg-white/5 border border-white/5 rounded-2xl p-4">
        <div class="grid grid-cols-5 gap-1 mb-2">
          <div class="text-center font-anton text-2xl text-red-400">B</div>
          <div class="text-center font-anton text-2xl text-yellow-400">I</div>
          <div class="text-center font-anton text-2xl text-teal-400">N</div>
          <div class="text-center font-anton text-2xl text-emerald-300">G</div>
          <div class="text-center font-anton text-2xl text-rose-400">O</div>
        </div>
        <div id="bingo-grid" class="grid grid-cols-5 gap-1.5"></div>
        <div class="mt-3 w-full bg-white/5 rounded-full h-2 overflow-hidden">
          <div id="prog-bar" class="h-full rounded-full bg-linear-to-r from-electric-violet-500 to-amber-400 transition-all duration-500" style="width:0%"></div>
        </div>
        <div id="prog-text" class="text-right text-[11px] text-white/30 font-rubik mt-1">0 / 24 marcados</div>

<div class="mt-4 grid grid-cols-2 gap-2">
  <button id="claim-h" class="bg-white/10 border border-white/10 rounded-xl px-3 py-2 text-xs font-rubik font-bold text-white hover:bg-white/15">
    ➖ Línea horizontal
  </button>
  <button id="claim-v" class="bg-white/10 border border-white/10 rounded-xl px-3 py-2 text-xs font-rubik font-bold text-white hover:bg-white/15">
    │ Línea vertical
  </button>
  <button id="claim-d" class="bg-white/10 border border-white/10 rounded-xl px-3 py-2 text-xs font-rubik font-bold text-white hover:bg-white/15">
    ✖ Diagonal
  </button>
  <button id="claim-bingo" class="bg-linear-to-br from-green-500 to-emerald-600 rounded-xl px-3 py-2 text-xs font-rubik font-black text-white hover:scale-[1.02]">
    🏆 BINGO
  </button>
</div>

<div id="claim-msg" class="hidden mt-3 text-center text-xs font-rubik font-bold"></div>
      </div>
    `;
      updateGrid();
      bindClaimButtons();
    }

    function updateGrid() {
      if (!myCard) return;
      const grid = $("#bingo-grid");
      if (!grid) return;
      grid.innerHTML = "";
      let markedCount = 0;
      const state = window.__bingoState || { drawn: [] };

      const baseCls =
        "aspect-square rounded-xl flex items-center justify-center font-anton text-lg select-none";

      for (let r = 0; r < 5; r++) {
        for (let c = 0; c < 5; c++) {
          const val = myCard[r][c];
          const cell = document.createElement("div");
          cell.className = baseCls;

          if (val === "FREE") {
            cell.textContent = "FREE";
            cell.className = `${baseCls} bg-linear-to-br from-electric-violet-500 to-fuchsia-600 text-white text-[10px] cursor-default tracking-wider`;
            markedCount++;
          } else {
            cell.textContent = val;
            cell.dataset.r = r;
            cell.dataset.c = c;
            cell.dataset.v = val;

            const isCalled = state.drawn.includes(val);
            const isMarked = marked.has(String(val));

            if (isMarked) {
              cell.className = `${baseCls} bg-linear-to-br from-amber-400 to-orange-500 text-stone-900 border-2 border-yellow-400 shadow-lg shadow-orange-500/40 marked`;
              markedCount++;
            } else if (isCalled) {
              cell.className = `${baseCls} bg-white/[0.03] text-white/40 border border-electric-violet-500/30 cursor-pointer transition-all duration-150 hover:bg-white/[0.06] hover:border-electric-violet-500/40 active:scale-90`;
            } else {
              cell.className = `${baseCls} bg-white/[0.06] text-white/70 border-2 border-transparent cursor-pointer transition-all duration-150 hover:border-electric-violet-500/40 hover:bg-white/[0.09] active:scale-90`;
            }

            cell.addEventListener("click", () => toggleCell(r, c, val));
          }
          grid.appendChild(cell);
        }
      }

      const pct = Math.round((markedCount / 25) * 100);
      const pb = $("#prog-bar");
      const pt = $("#prog-text");
      if (pb) pb.style.width = pct + "%";
      if (pt) pt.textContent = markedCount - 1 + " / 24 marcados";
    }

    function toggleCell(r, c, val) {
      const key = String(val);
      if (marked.has(key)) marked.delete(key);
      else marked.add(key);
      sessionStorage.setItem(
        "bingo-marked-" + sessionId,
        JSON.stringify([...marked]),
      );
      updateGrid();
    }

    function bindClaimButtons() {
      $("#claim-h")?.addEventListener("click", () =>
        claimPattern("LINEA_HORIZONTAL"),
      );
      $("#claim-v")?.addEventListener("click", () =>
        claimPattern("LINEA_VERTICAL"),
      );
      $("#claim-d")?.addEventListener("click", () =>
        claimPattern("DIAGONAL"),
      );
      $("#claim-bingo")?.addEventListener("click", () =>
        claimPattern("BINGO"),
      );
    }

    async function claimPattern(type) {
      const msg = $("#claim-msg");
      const buttons = ["#claim-h", "#claim-v", "#claim-d", "#claim-bingo"]
        .map((id) => $(id))
        .filter(Boolean);

      buttons.forEach((btn) => {
        btn.disabled = true;
        btn.classList.add("opacity-50", "cursor-not-allowed");
      });

      if (msg) {
        msg.classList.remove("hidden");
        msg.className =
          "mt-3 text-center text-xs font-rubik font-bold text-yellow-300";
        msg.textContent = "Enviando reclamo...";
      }

      try {
        const res = await fetch(`${API}/claim-pattern`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ session: sessionId, type }),
        });

        const data = await res.json();

        if (!res.ok) {
          if (msg) {
            msg.className =
              "mt-3 text-center text-xs font-rubik font-bold text-red-400";
            msg.textContent = data.error || "No se pudo reclamar";
          }
          return;
        }

        if (msg) {
          msg.className =
            "mt-3 text-center text-xs font-rubik font-bold text-green-400";
          msg.textContent = "✅ Reclamo enviado al bolillero";
        }
      } catch {
        if (msg) {
          msg.className =
            "mt-3 text-center text-xs font-rubik font-bold text-red-400";
          msg.textContent = "Error de conexión";
        }
      } finally {
        setTimeout(() => {
          buttons.forEach((btn) => {
            btn.disabled = false;
            btn.classList.remove("opacity-50", "cursor-not-allowed");
          });
        }, 1500);
      }
    }

    async function pollState() {
      const res = await fetch(`${API}/state?session=${sessionId}`);
      if (!res.ok) return;
      const state = await res.json();
      window.__bingoState = state;
      const drawn = state.drawn || [];
      const latest = drawn.length > 0 ? drawn[drawn.length - 1] : "—";

      const currEl = $("#curr-num");
      if (currEl) {
        if (drawn.length !== lastDrawn && drawn.length > 0) {
          currEl.classList.remove("ball-pop");
          void currEl.offsetWidth;
          currEl.classList.add("ball-pop");
          lastDrawn = drawn.length;
        }
        currEl.textContent = latest;
      }

      const histEl = $("#hist-row");
      if (histEl) {
        histEl.innerHTML = drawn
          .slice(-9)
          .reverse()
          .slice(1)
          .map((n) => `<span class="hist-chip">${n}</span>`)
          .join("");
      }

      if (cardRendered) updateGrid();

      const winBanner = $("#win-banner");
      const otherBanner = $("#other-banner");
      if (state.gameOver) {
        if (state.winner === username) {
          if (winBanner) winBanner.classList.add("show");
          const ws = $("#win-sub");
          if (ws) ws.textContent = state.winnerType || "";
          highlightWin(drawn);
        } else if (state.winner) {
          if (otherBanner) otherBanner.classList.add("show");
          const on = $("#other-name");
          if (on) on.textContent = state.winner + " ganó: " + state.winnerType;
        }
      }
    }

    function highlightWin(drawn) {
      if (!myCard) return;
      const has = (n) => n === "FREE" || marked.has(String(n));
      const toHighlight = [];

      for (let r = 0; r < 5; r++) {
        if (myCard[r].every(has)) {
          for (let c = 0; c < 5; c++) toHighlight.push([r, c]);
          break;
        }
      }
      for (let c = 0; c < 5; c++) {
        if (myCard.every((row) => has(row[c]))) {
          for (let r = 0; r < 5; r++) toHighlight.push([r, c]);
          break;
        }
      }
      if ([0, 1, 2, 3, 4].every((i) => has(myCard[i][i]))) {
        for (let i = 0; i < 5; i++) toHighlight.push([i, i]);
      }
      if ([0, 1, 2, 3, 4].every((i) => has(myCard[i][4 - i]))) {
        for (let i = 0; i < 5; i++) toHighlight.push([i, 4 - i]);
      }
      if (myCard.flat().every(has)) {
        for (let r = 0; r < 5; r++)
          for (let c = 0; c < 5; c++) toHighlight.push([r, c]);
      }

      $$(".cell").forEach((cell) => {
        const r = parseInt(cell.dataset.r);
        const c = parseInt(cell.dataset.c);
        if (toHighlight.some(([tr, tc]) => tr === r && tc === c)) {
          cell.classList.add("win-cell");
        }
      });
    }

    claimCard().then(() => {
      pollState();
      setInterval(pollState, 2500);
    });
  });
</script>
