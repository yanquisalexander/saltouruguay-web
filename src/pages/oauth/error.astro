---
import OAuthLayout from "@/layouts/OAuthLayout.astro";

const error = Astro.url.searchParams.get("error") || "unknown";
const errorDescription = Astro.url.searchParams.get("error_description") || Astro.url.searchParams.get("message") || "";
const scope = Astro.url.searchParams.get("scope") || "";

const ERROR_MESSAGES: Record<string, { title: string; description: string }> = {
    invalid_request: {
        title: "Solicitud inválida",
        description: "Faltan parámetros requeridos o son inválidos.",
    },
    invalid_client: {
        title: "Cliente inválido",
        description: "La aplicación solicitante no existe o no está aprobada.",
    },
    invalid_scope: {
        title: "Alcance inválido",
        description: scope
            ? `El alcance "${scope}" no está disponible.`
            : "Se solicitaron alcances inválidos.",
    },
    mismatched_redirect_uri: {
        title: "URI de redirección inválida",
        description: "La URI de redirección no coincide con la registrada.",
    },
    unsupported_response_type: {
        title: "Tipo de respuesta no soportado",
        description: "Solo se soporta response_type=code.",
    },
    access_denied: {
        title: "Acceso denegado",
        description: "Has cancelado la autorización.",
    },
};

const msg = ERROR_MESSAGES[error] || {
    title: "Error desconocido",
    description: errorDescription || "Ocurrió un error inesperado.",
};
---

<OAuthLayout title="Error &mdash; SaltoUruguayServer OAuth">
    <div class="flex flex-col items-center py-8 text-center">
        <div class="size-16 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-5">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-400">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
        </div>

        <h1 class="text-2xl font-anton text-white uppercase tracking-wide mb-2">
            {msg.title}
        </h1>

        <p class="text-white/50 text-sm max-w-[40ch] mx-auto leading-relaxed mb-6">
            {msg.description}
        </p>

        <a
            href="/"
            class="inline-flex items-center justify-center gap-2 rounded-xl text-sm font-bold h-11 px-6 bg-purple-600 hover:bg-purple-500 active:bg-purple-700 text-white transition-all shadow-lg shadow-purple-900/30"
        >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Volver al inicio
        </a>
    </div>
</OAuthLayout>
