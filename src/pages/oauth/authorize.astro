---
import { getSession } from "auth-astro/server";
import {
  getApprovedClient,
  getClientRedirectUris,
  validateRedirectUri,
} from "@/lib/oauth";
import { AVAILABLE_SCOPES, SCOPE_META } from "@/lib/oauth/scopes";
import OAuthLayout from "@/layouts/OAuthLayout.astro";

const session = await getSession(Astro.request);

if (!session) {
  const returnUrl = encodeURIComponent(Astro.url.pathname + Astro.url.search);
  return Astro.redirect(`/?login=true&redirect=${returnUrl}`, 302);
}

const clientId = Astro.url.searchParams.get("client_id");
const redirectUri = Astro.url.searchParams.get("redirect_uri");
const responseType = Astro.url.searchParams.get("response_type");
const scope = Astro.url.searchParams.get("scope");
const state = Astro.url.searchParams.get("state");
const codeChallenge = Astro.url.searchParams.get("code_challenge");
const codeChallengeMethod = Astro.url.searchParams.get("code_challenge_method");

if (!clientId || !redirectUri || !responseType || !scope) {
  return Astro.redirect("/oauth/error?error=invalid_request", 302);
}

const client = await getApprovedClient(clientId);
if (!client) {
  return Astro.redirect("/oauth/error?error=invalid_client", 302);
}

const allowedUris = await getClientRedirectUris(client.id);
if (!validateRedirectUri(redirectUri, allowedUris)) {
  return Astro.redirect("/oauth/error?error=mismatch_redirect_uri", 302);
}

if (responseType !== "code") {
  return Astro.redirect("/oauth/error?error=unsupported_response_type", 302);
}

const scopes = scope.split(" ").filter(Boolean);
const invalidScopes = scopes.filter(
  (s) => !(AVAILABLE_SCOPES as readonly string[]).includes(s),
);
if (invalidScopes.length > 0) {
  return Astro.redirect(
    `/oauth/error?error=invalid_scope&scope=${encodeURIComponent(invalidScopes.join(" "))}`,
    302,
  );
}

if (codeChallenge && codeChallengeMethod !== "S256") {
  return Astro.redirect(
    "/oauth/error?error=invalid_request&message=Only+S256+supported",
    302,
  );
}

const getScopeMeta = (scope: string) => {
  const meta = (
    SCOPE_META as Record<
      string,
      { name: string; description: string } | undefined
    >
  )[scope];
  return meta ?? { name: scope, description: "Scope" };
};
---

<OAuthLayout title={`Autorizar &mdash; ${client.name}`}>
  <div id="loading-bar" class="absolute top-0 left-0 h-1 w-full bg-white/5 overflow-hidden hidden">
    <div class="h-full bg-purple-500 animate-loading-bar"></div>
  </div>

  <header class="pt-6 pb-4 flex flex-col items-center">
    <div class="flex items-center justify-between gap-6 mb-6">
      <div class="relative group">
        <div class="absolute inset-0 bg-blue-500/20 blur-xl rounded-full opacity-50 group-hover:opacity-80 transition-opacity"></div>
        <img
          src="/favicon.svg"
          alt="SaltoUruguayServer"
          class="relative size-16 object-contain drop-shadow-lg"
        />
      </div>

      <div class="flex flex-col items-center gap-1 text-white/20">
        <div class="flex gap-1 animate-pulse">
          <div class="size-1.5 rounded-full bg-purple-500"></div>
          <div class="size-1.5 rounded-full bg-purple-500/50"></div>
          <div class="size-1.5 rounded-full bg-purple-500/20"></div>
        </div>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-500/50">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </div>

      <div class="relative group">
        <div class="absolute inset-0 bg-purple-500/20 blur-xl rounded-full opacity-50 group-hover:opacity-80 transition-opacity"></div>
        <img
          src={client.icon ||
            `https://ui-avatars.com/api/?name=${encodeURIComponent(client.name)}&background=random`}
          alt={client.name}
          class="relative size-16 object-contain rounded-full drop-shadow-lg"
        />
      </div>
    </div>

    <h2 class="text-lg font-anton text-white uppercase tracking-wide text-center">
      <span class="text-purple-400">{client.name}</span> quiere acceder<br />a tu cuenta
    </h2>
  </header>

  <div class="space-y-5">
    <div class="flex items-center gap-3 bg-white/5 p-2 px-4 rounded-xl mx-auto w-full max-w-[280px]">
      <span class="relative flex h-10 w-10 shrink-0 overflow-hidden rounded-full ring-2 ring-purple-500/30">
        <img
          class="aspect-square h-full w-full"
          alt="Avatar"
          src={session.user?.image ||
            `https://ui-avatars.com/api/?name=${encodeURIComponent(session.user?.name || "U")}&background=random`}
        />
      </span>
      <div class="min-w-0">
        <p class="text-sm font-medium text-white truncate">{session.user?.name || "Usuario"}</p>
        <p class="text-xs text-white/40 truncate">{session.user?.email}</p>
      </div>
    </div>

    <p class="text-white/60 text-sm text-balance text-center max-w-[44ch] mx-auto leading-relaxed">
      Al hacer clic en <strong class="text-white">"Autorizar"</strong> estás permitiendo a
      <strong class="text-white">{client.name}</strong>:
    </p>

    <ul class="flex flex-col gap-2 mx-auto max-w-[44ch]">
      {
        scopes.map((s) => {
          const meta = getScopeMeta(s);
          return (
            <li class="flex items-center gap-3 bg-white/5 rounded-xl px-4 py-3">
              <span class="size-5 rounded-full bg-purple-500/20 flex items-center justify-center shrink-0">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-purple-400">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <div class="flex flex-col">
                <span class="text-sm font-medium text-white">{meta.name}</span>
                <span class="text-xs text-white/40">{meta.description}</span>
              </div>
            </li>
          );
        })
      }
    </ul>

    <footer class="flex flex-col gap-2 pt-2">
      <button
        id="authorize"
        data-client-id={clientId}
        data-redirect-uri={redirectUri}
        data-scope={scope}
        data-state={state || ""}
        data-code-challenge={codeChallenge || ""}
        data-code-challenge-method={codeChallengeMethod || ""}
        class="inline-flex items-center justify-center gap-2 rounded-xl text-sm font-bold h-11 px-6 w-full bg-purple-600 hover:bg-purple-500 active:bg-purple-700 text-white transition-all cursor-pointer shadow-lg shadow-purple-900/30"
      >
        Autorizar
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
      <a
        href={redirectUri}
        class="inline-flex items-center justify-center gap-2 rounded-xl text-sm font-medium h-11 px-6 w-full text-white/40 hover:text-white/80 hover:bg-white/5 transition"
      >
        Cancelar
      </a>
    </footer>
  </div>
</OAuthLayout>

<style>
  @keyframes loading-bar {
    0% { width: 0%; transform: translateX(-100%); }
    50% { width: 50%; }
    100% { width: 100%; transform: translateX(100%); }
  }
  .animate-loading-bar {
    animation: loading-bar 1.5s infinite linear;
  }
</style>

<script>
  import { $ } from "@/lib/dom-selector";
  import { actions } from "astro:actions";

  document.addEventListener("DOMContentLoaded", () => {
    const $btn = $("#authorize") as HTMLButtonElement | null;
    const $bar = $("#loading-bar") as HTMLDivElement | null;
    if (!$btn) return;

    const showLoading = () => {
      if ($bar) $bar.classList.remove("hidden");
    };
    const hideLoading = () => {
      if ($bar) $bar.classList.add("hidden");
    };
    const resetBtn = () => {
      $btn.disabled = false;
      $btn.innerHTML = 'Autorizar <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
    };

    $btn.addEventListener("click", async () => {
      const {
        clientId,
        redirectUri,
        scope,
        state,
        codeChallenge,
        codeChallengeMethod,
      } = $btn.dataset;
      if (!clientId || !redirectUri || !scope) return;

      $btn.disabled = true;
      $btn.innerHTML = 'Autorizando... <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>';
      showLoading();

      const scopes = scope.split(" ").filter(Boolean);

      try {
        const resp = await actions.oauth.authorize({
          clientId,
          redirectUri,
          scopes,
          state: state || undefined,
          codeChallenge: codeChallenge || undefined,
          codeChallengeMethod: codeChallengeMethod || undefined,
        });

        if (resp.error) {
          alert(resp.error.message || "Error al autorizar");
          hideLoading();
          resetBtn();
          return;
        }

        if (resp.data?.redirectUri) {
          window.location.href = resp.data.redirectUri;
        }
      } catch (e) {
        alert("Error al autorizar");
        hideLoading();
        resetBtn();
      }
    });
  });
</script>
