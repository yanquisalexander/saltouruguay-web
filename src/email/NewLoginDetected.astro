---
import EmailLayout from "./EmailLayout.astro";

interface Props {
  date: Date;
  location: string;
  device: string;
  browser: string;
}

const { date, location = "Desconocida", device = "Desconocido", browser = "Desconocido" } = Astro.props;
---

<EmailLayout title="Nuevo inicio de sesión" previewText="Alerta de seguridad: Se ha detectado un nuevo inicio de sesión en tu cuenta.">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding-bottom:4px">
        <span style="display:inline-block;background-color:rgba(239,68,68,0.12);color:#f87171;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:6px 14px;border-radius:20px;border:1px solid rgba(239,68,68,0.15)">
          ⚠ Alerta de seguridad
        </span>
      </td>
    </tr>
  </table>

  <h1 style="font-size:24px;font-weight:800;text-align:center;color:#f87171;margin:16px 0 8px;letter-spacing:-0.02em">
    Nuevo inicio de sesión detectado
  </h1>

  <p style="font-size:15px;color:rgba(255,255,255,0.55);text-align:center;line-height:1.6;margin:0 0 24px">
    Se ha iniciado sesión en tu cuenta de SaltoUruguayServer desde un dispositivo o ubicación no habitual.
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.06);margin-bottom:20px">
    <tr>
      <td style="padding:20px">
        <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.35);margin:0 0 16px">
          Detalles del inicio de sesión
        </h2>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
              <span style="font-size:12px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.05em;display:block">Fecha y hora</span>
              <span style="font-size:14px;color:rgba(255,255,255,0.8);display:block;margin-top:2px">{new Date(date).toLocaleString("es-ES", { year: "numeric", month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit" })} UTC</span>
            </td>
          </tr>
          <tr>
            <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
              <span style="font-size:12px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.05em;display:block">Ubicación</span>
              <span style="font-size:14px;color:rgba(255,255,255,0.8);display:block;margin-top:2px">{location}</span>
            </td>
          </tr>
          <tr>
            <td style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04)">
              <span style="font-size:12px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.05em;display:block">Dispositivo</span>
              <span style="font-size:14px;color:rgba(255,255,255,0.8);display:block;margin-top:2px">{device}</span>
            </td>
          </tr>
          <tr>
            <td style="padding:10px 0">
              <span style="font-size:12px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.05em;display:block">Navegador</span>
              <span style="font-size:14px;color:rgba(255,255,255,0.8);display:block;margin-top:2px">{browser}</span>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:rgba(234,179,8,0.06);border-radius:12px;border:1px solid rgba(234,179,8,0.12);margin-bottom:24px">
    <tr>
      <td style="padding:16px 20px">
        <p style="font-size:13px;color:#fde047;font-weight:600;margin:0;line-height:1.5">
          Si no reconoces esta actividad, recomendamos que cambies tu contraseña de Twitch y revises la seguridad de tu cuenta inmediatamente.
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding-bottom:16px">
        <a href="https://saltouruguayserver.com/account/security" style="display:inline-block;background-color:#ef4444;color:#ffffff;text-decoration:none;font-weight:700;font-size:14px;padding:14px 32px;border-radius:10px;letter-spacing:0.03em;box-sizing:border-box">
          REVISAR SEGURIDAD
        </a>
      </td>
    </tr>
  </table>

  <p style="font-size:14px;color:rgba(255,255,255,0.45);text-align:center;line-height:1.6;margin:0">
    Si fuiste tú, podés ignorar este mensaje de forma segura.
  </p>
</EmailLayout>
