---
import EmailLayout from "./EmailLayout.astro";
---

<EmailLayout title="Pre-inscripción SaltoCraft Extremo 3" previewText="¡Pre-inscripción exitosa para SaltoCraft Extremo 3! Mantente atento a Discord.">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px">
    <tr>
      <td>
        <img alt="SaltoCraft Extremo 3" src="https://img.youtube.com/vi/fuDkwZ6DdPQ/maxresdefault.jpg" width="100%" style="display:block;width:100%;height:auto;border-radius:12px;border:1px solid rgba(255,255,255,0.06)" />
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding-bottom:16px">
        <span style="display:inline-block;background-color:rgba(16,185,129,0.12);color:#34d399;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:6px 14px;border-radius:20px;border:1px solid rgba(16,185,129,0.15)">
          ✓ Pre-inscripción exitosa
        </span>
      </td>
    </tr>
  </table>

  <h1 style="font-size:24px;font-weight:800;text-align:center;color:#60a5fa;margin:0 0 16px;letter-spacing:-0.02em">
    ¡Te has pre-inscrito correctamente!
  </h1>

  <p style="font-size:14px;color:rgba(255,255,255,0.6);line-height:1.6;margin:0 0 8px">
    Estimado jugador:
  </p>

  <p style="font-size:14px;color:rgba(255,255,255,0.6);line-height:1.6;margin:0 0 8px">
    ¡Felicitaciones! Tu pre-inscripción para <strong style="color:rgba(255,255,255,0.8)">SaltoCraft Extremo 3</strong> ha sido confirmada exitosamente. Ahora formas parte de los jugadores que tendrán acceso prioritario a esta nueva aventura extrema llena de desafíos únicos.
  </p>

  <p style="font-size:14px;color:#fde047;font-weight:600;line-height:1.6;margin:8px 0 24px">
    Mantente atento a nuestro Discord oficial para más información.
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:rgba(88,28,135,0.25);border-radius:12px;border:1px solid rgba(168,85,247,0.15);margin-bottom:16px">
    <tr>
      <td style="padding:20px">
        <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#c4b5fd;margin:0 0 12px">
          Próximos pasos
        </h2>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td style="padding:6px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:6px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Únete a nuestro Discord si aún no lo has hecho</td>
          </tr>
          <tr>
            <td style="padding:6px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:6px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Busca el canal <strong style="color:rgba(255,255,255,0.8)">#saltocraft-extremo-3</strong></td>
          </tr>
          <tr>
            <td style="padding:6px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:6px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Recibirás notificaciones sobre la fecha de lanzamiento</td>
          </tr>
          <tr>
            <td style="padding:6px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:6px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Las reglas especiales serán publicadas allí</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:8px 0 20px">
        <a href="https://discord.gg/pdAk3QdqCK" style="display:inline-block;background-color:#5865f2;color:#ffffff;text-decoration:none;font-weight:700;font-size:14px;padding:14px 32px;border-radius:10px;letter-spacing:0.03em;box-sizing:border-box">
          UNIRSE A DISCORD
        </a>
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:rgba(185,28,28,0.15);border-radius:12px;border:1px solid rgba(239,68,68,0.15);margin-bottom:16px">
    <tr>
      <td style="padding:20px">
        <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#fca5a5;margin:0 0 8px">
          Modo Extremo
        </h2>
        <p style="font-size:14px;color:rgba(255,255,255,0.65);line-height:1.6;margin:0">
          Esta versión incluye modificaciones especiales que harán tu experiencia más desafiante. Solo los más preparados sobrevivirán a los nuevos obstáculos y mecánicas extremas.
        </p>
      </td>
    </tr>
  </table>

  <p style="font-size:14px;color:rgba(255,255,255,0.6);text-align:center;line-height:1.6;margin:8px 0 0">
    ¡Nos vemos en el juego extremo!
  </p>

  <p style="font-size:14px;font-weight:600;color:rgba(255,255,255,0.7);text-align:center;line-height:1.6;margin:4px 0 0">
    El equipo de SaltoUruguayServer
  </p>
</EmailLayout>
