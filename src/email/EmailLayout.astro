---
interface Props {
  title?: string;
  previewText?: string;
}

const { title, previewText } = Astro.props;
---

<!doctype html>
<html dir="ltr" lang="es">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body style="margin:0;padding:0;background-color:#050505;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif">
    <div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0">
      {previewText || title || ""}
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#050505">
      <tr>
        <td align="center" style="padding:32px 16px">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#0a0a0a;border:1px solid rgba(255,255,255,0.08);border-radius:16px">
            <tr>
              <td style="padding:36px 28px">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" style="padding-bottom:28px;border-bottom:1px solid rgba(255,255,255,0.06)">
                      <img src="https://saltouruguayserver.com/images/logo-email.png" alt="SaltoUruguayServer" width="56" height="56" style="display:block;width:56px;height:auto;border-radius:12px;box-shadow:0 0 30px rgba(168,85,247,0.12)" />
                    </td>
                  </tr>
                </table>
                <slot />
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="padding-top:28px;border-top:1px solid rgba(255,255,255,0.06)">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                          <td align="center" style="font-size:12px;color:rgba(255,255,255,0.22);padding-bottom:6px">
                            <a href="https://twitch.tv/saltouruguayserver" style="color:rgba(255,255,255,0.3);text-decoration:underline;text-underline-offset:3px">Twitch</a>
                            &nbsp;&nbsp;•&nbsp;&nbsp;
                            <a href="https://saltouruguayserver.com/preferences" style="color:rgba(255,255,255,0.3);text-decoration:underline;text-underline-offset:3px">Preferencias</a>
                            &nbsp;&nbsp;•&nbsp;&nbsp;
                            <a href="https://saltouruguayserver.com/unsubscribe" style="color:rgba(255,255,255,0.3);text-decoration:underline;text-underline-offset:3px">Cancelar suscripción</a>
                          </td>
                        </tr>
                        <tr>
                          <td align="center" style="font-size:9px;color:rgba(255,255,255,0.1);font-family:monospace;letter-spacing:0.15em;padding-top:6px">
                            SaltoUruguayServer
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
