---
import EmailLayout from "./EmailLayout.astro";

interface Props {
  displayName: string;
}

const { displayName } = Astro.props;
---

<EmailLayout title="Autorización de Twitch revocada" previewText="Autorización de Twitch revocada: Se han cerrado todas tus sesiones por seguridad.">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding-bottom:4px">
        <span style="display:inline-block;background-color:rgba(168,85,247,0.12);color:#c084fc;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:6px 14px;border-radius:20px;border:1px solid rgba(168,85,247,0.15)">
          Sesiones cerradas
        </span>
      </td>
    </tr>
  </table>

  <h1 style="font-size:24px;font-weight:800;text-align:center;color:#c084fc;margin:16px 0 8px;letter-spacing:-0.02em">
    Autorización de Twitch revocada
  </h1>

  <p style="font-size:15px;color:rgba(255,255,255,0.55);text-align:center;line-height:1.6;margin:0 0 20px">
    Hola, <strong style="color:rgba(255,255,255,0.85)">{displayName}</strong>.
  </p>

  <p style="font-size:14px;color:rgba(255,255,255,0.6);line-height:1.6;margin:0 0 8px">
    Hemos detectado que tu autorización con Twitch ha sido revocada. Esto puede deberse a un cambio de contraseña en tu cuenta de Twitch o a una revocación manual de los permisos.
  </p>

  <p style="font-size:14px;color:rgba(255,255,255,0.6);line-height:1.6;margin:0 0 24px">
    Por motivos de seguridad, hemos cerrado todas tus sesiones activas en SaltoUruguayServer.
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.06);margin-bottom:20px">
    <tr>
      <td style="padding:20px">
        <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.35);margin:0 0 12px">
          ¿Qué significa esto?
        </h2>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td style="padding:8px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:8px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Todas tus sesiones han sido cerradas por seguridad</td>
          </tr>
          <tr>
            <td style="padding:8px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:8px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Para volver a usar nuestros servicios, simplemente inicia sesión nuevamente</td>
          </tr>
          <tr>
            <td style="padding:8px 0;vertical-align:top;width:20px;color:rgba(255,255,255,0.3);font-size:14px">•</td>
            <td style="padding:8px 0;font-size:14px;color:rgba(255,255,255,0.65);line-height:1.5">Si no vuelves a conectarte en los próximos 30 días, tus datos serán eliminados de nuestra web</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:rgba(234,179,8,0.06);border-radius:12px;border:1px solid rgba(234,179,8,0.12);margin-bottom:24px">
    <tr>
      <td style="padding:16px 20px">
        <p style="font-size:13px;color:#fde047;font-weight:600;margin:0;line-height:1.5">
          Si no has realizado ningún cambio en tu cuenta de Twitch, te recomendamos verificar la seguridad de tu cuenta inmediatamente.
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding-bottom:16px">
        <a href="https://saltouruguayserver.com" style="display:inline-block;background-color:#9333ea;color:#ffffff;text-decoration:none;font-weight:700;font-size:14px;padding:14px 32px;border-radius:10px;letter-spacing:0.03em;box-sizing:border-box">
          INICIAR SESIÓN NUEVAMENTE
        </a>
      </td>
    </tr>
  </table>

  <p style="font-size:14px;color:rgba(255,255,255,0.45);text-align:center;line-height:1.6;margin:0">
    Si tenés alguna pregunta, no dudes en contactar a nuestro equipo de soporte.
  </p>
</EmailLayout>
