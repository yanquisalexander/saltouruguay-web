---
import { Container3D } from "@/components/Container3D";
import { MemberCard } from "@/components/MemberCard";
import {
  LucideSparkles,
  LucideArrowRight,
  LucideIdCard,
  LucideZap,
  LucidePalette,
} from "lucide-preact";
---

<section id="news-on-page" class="relative py-16 md:py-24 px-4 overflow-hidden">
  {/* Fondo Ambiental */}
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div
      class="absolute top-1/4 right-0 -translate-y-1/2 w-[400px] h-[400px] md:w-[600px] md:h-[600px] bg-yellow-500/10 blur-[120px] rounded-full"
    >
    </div>
  </div>

  <div class="max-w-7xl mx-auto">
    {/* HEADER DE SECCIÓN - Centrado en móvil */}
    <div class="text-center mb-10 md:mb-16">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 text-[10px] md:text-xs font-bold uppercase tracking-widest mb-6"
      >
        <LucideSparkles size={14} /> Nueva Funcionalidad
      </div>

      <h2
        class="text-4xl sm:text-5xl md:text-6xl font-anton text-white uppercase tracking-tight leading-none"
      >
        Tu Identidad
        <span
          class="block text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-500"
          >Saltana</span
        >
      </h2>

      <p
        class="text-white/60 font-rubik text-base md:text-lg max-w-lg mx-auto mt-4 leading-relaxed"
      >
        Reclama tu <strong class="text-white/80">Member Card</strong> única, personalízala
        con stickers exclusivos y presume tu rango en la comunidad.
      </p>
    </div>

    {/* DEMO 3D - Primero en móvil, a la derecha en desktop */}
    <div class="order-first lg:order-none mb-10 lg:mb-0">
      <div
        class="relative w-full max-w-sm mx-auto aspect-[1.95/1] md:aspect-auto md:h-[400px] lg:h-[450px] perspective-1000"
      >
        {/* Glow detrás */}
        <div
          class="absolute inset-0 bg-gradient-to-b from-yellow-500/10 to-transparent rounded-full blur-3xl transform scale-75"
        >
        </div>

        <div
          class="relative z-10 w-full h-full transform transition-transform duration-500 hover:scale-105"
        >
          <Container3D client:only="preact">
            <MemberCard
              client:idle
              user={{
                username: "SaltoUruguayServer",
                avatar:
                  "https://static-cdn.jtvnw.net/jtv_user_pictures/224d6e65-109b-4976-9bf9-61f8404220d7-profile_image-300x300.png",
              }}
              number={1}
              selectedStickers={{
                limit: 2,
                list: ["saltoSorpresa", "saltoBaile"],
              }}
            />
          </Container3D>
        </div>

        {/* Nota flotante - reposicionada */}
        <div
          class="absolute -bottom-6 md:-bottom-8 left-1/2 -translate-x-1/2 bg-black/80 backdrop-blur-md border border-white/10 px-3 py-1.5 md:px-4 md:py-2 rounded-full text-[9px] md:text-[10px] text-white/50 uppercase tracking-widest whitespace-nowrap"
        >
          Interactúa con la tarjeta
        </div>
      </div>
    </div>

    {/* GRID DE 2 COLUMNAS: Beneficios + CTA */}
    <div class="grid md:grid-cols-2 gap-6 lg:gap-10 mt-10">
      {/* Columna izquierda: Beneficios */}
      <div class="space-y-4">
        <div
          class="flex items-start gap-3 p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors"
        >
          <div class="p-2.5 bg-blue-500/20 text-blue-400 rounded-lg shrink-0">
            <LucideZap size={18} />
          </div>
          <div>
            <h4 class="text-white font-bold text-sm uppercase">
              Sincronización Twitch
            </h4>
            <p class="text-white/50 text-xs mt-1 leading-relaxed">
              Con tu suscripción podrás personalizar el diseño de tu tarjeta.
            </p>
          </div>
        </div>
        <div
          class="flex items-start gap-3 p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors"
        >
          <div
            class="p-2.5 bg-purple-500/20 text-purple-400 rounded-lg shrink-0"
          >
            <LucidePalette size={18} />
          </div>
          <div>
            <h4 class="text-white font-bold text-sm uppercase">
              Personalización Total
            </h4>
            <p class="text-white/50 text-xs mt-1 leading-relaxed">
              Elige tus stickers favoritos y desbloquea nuevos con logros.
            </p>
          </div>
        </div>
      </div>

      {/* Columna derecha: CTAs */}
      <div class="flex flex-col justify-center items-center md:items-end gap-4">
        <a
          href="/comunidad/member-card"
          class="w-full md:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-yellow-500 hover:bg-yellow-400 text-black font-anton text-xl uppercase tracking-wide rounded-xl transition-all hover:scale-105 shadow-[0_0_20px_rgba(234,179,8,0.3)]"
        >
          <LucideIdCard size={20} /> Crear mi Tarjeta
        </a>
        <a
          href="/comunidad"
          class="w-full md:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-bold uppercase tracking-wide rounded-xl transition-all text-sm"
        >
          Ver Galería <LucideArrowRight size={14} />
        </a>
      </div>
    </div>

    {/* ROADMAP FOOTER */}
    <div class="mt-16 pt-8 border-t border-white/5">
      <div
        class="flex flex-col md:flex-row items-center justify-between gap-4 opacity-60 hover:opacity-100 transition-opacity"
      >
        <div class="flex items-center gap-3">
          <span class="size-2 rounded-full bg-blue-500 animate-pulse shrink-0"
          ></span>
          <p class="text-sm font-rubik text-white/80 text-center md:text-left">
            <span class="font-bold text-white uppercase tracking-wider mr-2"
              >Roadmap:</span
            >
            Nuevas secciones y contenido exclusivo en camino.
          </p>
        </div>
        <a
          href="/comunidad"
          class="flex items-center gap-2 text-xs font-bold text-white uppercase tracking-widest hover:text-yellow-400 transition-colors shrink-0"
        >
          Ver hoja de ruta <LucideArrowRight size={14} />
        </a>
      </div>
    </div>
  </div>
</section>
