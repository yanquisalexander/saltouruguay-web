---
// PencaCallToAction.astro
// Bloque llamador para la Penca Saltana — mismo lenguaje visual que el hero
---

<a
  href="https://www.penca.saltouruguayserver.com"
  target="_blank"
  rel="noopener noreferrer"
  class="penca-cta group"
  aria-label="Participar en la Penca Saltana"
>
  {/* Partículas internas del card */}
  <div class="penca-particles" aria-hidden="true">
    <span class="pp pp-1"></span>
    <span class="pp pp-2"></span>
    <span class="pp pp-3"></span>
    <span class="pp pp-4"></span>
    <span class="pp pp-5"></span>
    <span class="pp pp-6"></span>
  </div>

  {/* Orbe de luz animado de fondo */}
  <div class="penca-orb" aria-hidden="true"></div>

  {/* Borde animado */}
  <div class="penca-border" aria-hidden="true"></div>

  {/* Contenido */}
  <div class="penca-content">
    {/* Badge */}
    <span class="penca-badge">
      <span class="penca-badge-dot"></span>
      ACTIVO AHORA
    </span>

    {/* Imagen / ilustración central */}
    <div class="penca-image-wrapper">
      <div class="penca-trophy" aria-hidden="true">
        <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="penca-trophy-svg">
          {/* Copa */}
          <path
            d="M35 20 H85 V60 C85 82 60 92 60 92 C60 92 35 82 35 60 Z"
            fill="url(#cupGrad)"
            stroke="url(#cupStroke)"
            stroke-width="2"
          />
          {/* Manijas */}
          <path d="M35 30 C20 30 20 55 35 55" stroke="url(#handleGrad)" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path d="M85 30 C100 30 100 55 85 55" stroke="url(#handleGrad)" stroke-width="3" fill="none" stroke-linecap="round"/>
          {/* Pie de copa */}
          <rect x="50" y="92" width="20" height="8" rx="2" fill="url(#baseGrad)"/>
          <rect x="42" y="100" width="36" height="6" rx="3" fill="url(#baseGrad)"/>
          {/* Estrella interior */}
          <path
            d="M60 38 L63 48 L74 48 L65 54 L68 64 L60 58 L52 64 L55 54 L46 48 L57 48 Z"
            fill="url(#starGrad)"
            opacity="0.9"
          />
          <defs>
            <linearGradient id="cupGrad" x1="35" y1="20" x2="85" y2="92" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#f59e0b"/>
              <stop offset="50%" stop-color="#fbbf24"/>
              <stop offset="100%" stop-color="#d97706"/>
            </linearGradient>
            <linearGradient id="cupStroke" x1="35" y1="20" x2="85" y2="92" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#fde68a"/>
              <stop offset="100%" stop-color="#f59e0b"/>
            </linearGradient>
            <linearGradient id="handleGrad" x1="0" y1="0" x2="0" y2="1" gradientUnits="objectBoundingBox">
              <stop offset="0%" stop-color="#fde68a"/>
              <stop offset="100%" stop-color="#d97706"/>
            </linearGradient>
            <linearGradient id="baseGrad" x1="42" y1="92" x2="78" y2="106" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#fbbf24"/>
              <stop offset="100%" stop-color="#b45309"/>
            </linearGradient>
            <linearGradient id="starGrad" x1="46" y1="38" x2="74" y2="64" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#fff7ed"/>
              <stop offset="100%" stop-color="#fde68a"/>
            </linearGradient>
          </defs>
        </svg>
        {/* Destellos alrededor de la copa */}
        <span class="glint g1">✦</span>
        <span class="glint g2">✦</span>
        <span class="glint g3">✦</span>
      </div>
    </div>

    {/* Textos */}
    <div class="penca-texts">
      <p class="penca-eyebrow">Torneo de pronósticos</p>
      <h2 class="penca-title">
        Penca<br/>
        <span class="penca-title-accent">Saltana</span>
      </h2>
      <p class="penca-description">
        Predecí los resultados, subí en el ranking y competí contra la comunidad. ¡El campeón se lleva la gloria!
      </p>
    </div>

    {/* CTA Button */}
    <div class="penca-button">
      <span class="penca-button-text">¡Participar ahora!</span>
      <svg class="penca-arrow" viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </div>
  </div>
</a>

<style>
  /* ===== CARD PRINCIPAL ===== */
  .penca-cta {
    display: block;
    position: relative;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    border-radius: 24px;
    padding: 2px; /* espacio para el borde animado */
    background: transparent;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .penca-cta:hover {
    transform: translateY(-6px) scale(1.01);
  }

  /* ===== BORDE ANIMADO (gradient sweep) ===== */
  .penca-border {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 2px;
    background: conic-gradient(
      from var(--angle, 0deg),
      #f59e0b,
      #fbbf24,
      #8b5cf6,
      #6366f1,
      #f59e0b
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: rotateBorder 4s linear infinite;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .penca-cta:hover .penca-border {
    opacity: 1;
    animation-duration: 2s;
  }

  @property --angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes rotateBorder {
    to { --angle: 360deg; }
  }

  /* ===== CONTENIDO INTERNO ===== */
  .penca-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    border-radius: 22px;
    padding: 2rem 2rem 1.75rem;
    background: rgba(10, 8, 20, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    overflow: hidden;
  }

  /* ===== ORB DE LUZ ===== */
  .penca-orb {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(245, 158, 11, 0.18) 0%,
      rgba(139, 92, 246, 0.08) 50%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
    animation: orbPulse 3s ease-in-out infinite;
    transition: opacity 0.3s;
  }

  .penca-cta:hover .penca-orb {
    opacity: 1.5;
    animation-duration: 1.5s;
  }

  @keyframes orbPulse {
    0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
    50% { opacity: 1; transform: translateX(-50%) scale(1.15); }
  }

  /* ===== PARTÍCULAS INTERNAS ===== */
  .penca-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .pp {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(251, 191, 36, 0.7), transparent 70%);
    animation: ppFloat linear infinite;
    opacity: 0;
  }

  .pp-1 { width: 4px; height: 4px; left: 15%; animation-duration: 8s; animation-delay: 0s; }
  .pp-2 { width: 3px; height: 3px; left: 30%; animation-duration: 10s; animation-delay: 1.5s; }
  .pp-3 { width: 5px; height: 5px; left: 55%; animation-duration: 7s; animation-delay: 3s; }
  .pp-4 { width: 3px; height: 3px; left: 70%; animation-duration: 9s; animation-delay: 0.5s; }
  .pp-5 { width: 4px; height: 4px; left: 85%; animation-duration: 11s; animation-delay: 2s; }
  .pp-6 { width: 3px; height: 3px; left: 45%; animation-duration: 8.5s; animation-delay: 4s; }

  @keyframes ppFloat {
    0%   { transform: translateY(100%); opacity: 0; }
    10%  { opacity: 0.8; }
    90%  { opacity: 0.5; }
    100% { transform: translateY(-20px); opacity: 0; }
  }

  /* ===== BADGE ===== */
  .penca-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #fbbf24;
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.3);
    border-radius: 999px;
    padding: 4px 12px;
    text-transform: uppercase;
    z-index: 2;
  }

  .penca-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fbbf24;
    box-shadow: 0 0 6px #fbbf24;
    animation: dotBlink 1.5s ease-in-out infinite;
  }

  @keyframes dotBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ===== IMAGEN / COPA ===== */
  .penca-image-wrapper {
    position: relative;
    z-index: 2;
  }

  .penca-trophy {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .penca-trophy-svg {
    width: 110px;
    height: 110px;
    filter: drop-shadow(0 0 20px rgba(245, 158, 11, 0.5)) drop-shadow(0 0 40px rgba(245, 158, 11, 0.2));
    animation: trophyFloat 4s ease-in-out infinite;
    transition: filter 0.3s;
  }

  .penca-cta:hover .penca-trophy-svg {
    filter: drop-shadow(0 0 30px rgba(245, 158, 11, 0.8)) drop-shadow(0 0 60px rgba(245, 158, 11, 0.3));
  }

  @keyframes trophyFloat {
    0%, 100% { transform: translateY(0px) rotate(-1deg); }
    50% { transform: translateY(-8px) rotate(1deg); }
  }

  /* Destellos */
  .glint {
    position: absolute;
    color: #fde68a;
    font-size: 12px;
    animation: glintAnim ease-in-out infinite;
    opacity: 0;
    text-shadow: 0 0 8px #fbbf24;
  }

  .g1 { top: 5px; right: 10px; animation-duration: 2.5s; animation-delay: 0s; }
  .g2 { top: 20px; left: 5px; animation-duration: 3s; animation-delay: 0.8s; font-size: 8px; }
  .g3 { bottom: 10px; right: 0px; animation-duration: 2s; animation-delay: 1.5s; font-size: 10px; }

  @keyframes glintAnim {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* ===== TEXTOS ===== */
  .penca-texts {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    z-index: 2;
  }

  .penca-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .penca-title {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.2rem, 6vw, 3rem);
    line-height: 1;
    color: white;
    margin: 0;
    letter-spacing: 0.05em;
    transition: text-shadow 0.3s;
  }

  .penca-cta:hover .penca-title {
    text-shadow: 0 0 30px rgba(255, 255, 255, 0.2);
  }

  .penca-title-accent {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 40%, #d97706 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 12px rgba(245, 158, 11, 0.4));
  }

  .penca-description {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    max-width: 300px;
    line-height: 1.6;
    margin: 0.25rem 0 0;
  }

  /* ===== BOTÓN CTA ===== */
  .penca-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.65rem 1.5rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #1a0e00;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 20px rgba(245, 158, 11, 0.3),
      0 4px 12px rgba(0, 0, 0, 0.3);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 2;
  }

  .penca-cta:hover .penca-button {
    box-shadow:
      0 0 35px rgba(245, 158, 11, 0.6),
      0 8px 20px rgba(0, 0, 0, 0.4);
    transform: scale(1.05);
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  }

  .penca-arrow {
    transition: transform 0.3s;
  }

  .penca-cta:hover .penca-arrow {
    transform: translateX(4px);
  }

  /* ===== RESPONSIVE ===== */
  @media (min-width: 640px) {
    .penca-content {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 1.5rem;
      padding: 2rem 2.25rem;
    }

    .penca-texts {
      align-items: flex-start;
    }

    .penca-description {
      max-width: 220px;
    }

    .penca-button {
      white-space: nowrap;
    }

    .penca-image-wrapper {
      flex-shrink: 0;
    }
  }
</style>
