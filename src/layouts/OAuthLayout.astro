---
import "@/assets/styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[#050505] text-white font-rubik antialiased">
    <div class="fixed inset-0 -z-10">
      <div class="absolute inset-0 bg-[url('/images/pattern-grid.svg')] opacity-[0.03]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-purple-900/10 blur-[150px] rounded-full pointer-events-none"></div>
    </div>
    <main class="mx-auto flex justify-center items-center min-h-screen h-full px-4">
      <div class="w-full max-w-md p-4 animate-in fade-in zoom-in-95 duration-500">
        <div class="relative bg-[#0a0a0a] border border-white/5 rounded-2xl p-5 md:border-white/10 md:rounded-3xl md:p-8 shadow-2xl shadow-purple-900/20 overflow-hidden">
          <slot />
        </div>
      </div>
    </main>
  </body>
</html>
